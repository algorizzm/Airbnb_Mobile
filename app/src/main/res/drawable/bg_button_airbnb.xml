<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Pressed State -->
    <item android:state_pressed="true">
        <shape>
            <gradient
                android:startColor="#E11D48"
                android:endColor="#D70466"
                android:angle="0"/>

            <corners android:radius="14dp"/>
        </shape>
    </item>

    <!-- Default State -->
    <item>
        <shape>
            <gradient
                android:startColor="#FF385C"
                android:endColor="#E61E4D"
                android:angle="0"/>

            <corners android:radius="14dp"/>
        </shape>
    </item>

</selector>