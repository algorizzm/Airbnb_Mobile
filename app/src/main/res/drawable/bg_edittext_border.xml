<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <!-- Background -->
    <solid android:color="#121212" />

    <!-- Rounded corners -->
    <corners android:radius="14dp" />

    <!-- Border (green outline) -->
    <stroke
        android:width="1.5dp"
        android:color="#00E676" />

    <!-- Inner padding (important for spacing) -->
    <padding
        android:left="12dp"
        android:right="12dp"
        android:top="12dp"
        android:bottom="12dp" />

</shape>