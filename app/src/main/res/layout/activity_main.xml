<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <!-- BOTTOM NAV ANCHOR GUIDELINE -->
    <!-- This guideline marks where the bottom navigation starts.
         Both nav bars are positioned here, ensuring the fragment container
         has a stable constraint regardless of which nav bar is visible. -->
    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guidelineBottomNav"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_end="72dp" />

    <!-- NAV HOST -->
    <androidx.fragment.app.FragmentContainerView
        android:id="@+id/nav_host_fragment"
        android:name="androidx.navigation.fragment.NavHostFragment"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:navGraph="@navigation/nav_graph"
        app:defaultNavHost="true"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/guidelineBottomNav"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ===================================================== -->
    <!-- TRAVELER BOTTOM NAV (default visible)                  -->
    <!-- ===================================================== -->
    <LinearLayout
        android:id="@+id/navBarBg"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:minHeight="72dp"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingTop="6dp"
        android:paddingBottom="10dp"
        android:background="@drawable/bg_bottom_nav"
        android:elevation="8dp"
        android:weightSum="5"
        app:layout_constraintTop_toBottomOf="@id/guidelineBottomNav"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Explore -->
        <LinearLayout
            android:id="@+id/navExplore"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackgroundBorderless">

            <ImageView
                android:id="@+id/navIconExplore"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_explore"
                app:tint="#FF385C"
                android:contentDescription="Explore"/>

            <TextView
                android:id="@+id/navLabelExplore"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Explore"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="#FF385C"
                android:layout_marginTop="2dp"/>
        </LinearLayout>

        <!-- Wishlists -->
        <LinearLayout
            android:id="@+id/navWishlists"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackgroundBorderless">

            <ImageView
                android:id="@+id/navIconWishlists"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_heart"
                app:tint="#717171"
                android:contentDescription="Wishlists"/>

            <TextView
                android:id="@+id/navLabelWishlists"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Wishlists"
                android:textSize="11sp"
                android:textColor="#717171"
                android:layout_marginTop="2dp"/>
        </LinearLayout>

        <!-- Trips -->
        <LinearLayout
            android:id="@+id/navTrips"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackgroundBorderless">

            <ImageView
                android:id="@+id/navIconTrips"
                android:layout_width="48dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_airbnb"
                app:tint="#717171"
                android:contentDescription="Trips"/>

            <TextView
                android:id="@+id/navLabelTrips"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Trips"
                android:textSize="11sp"
                android:textColor="#717171"
                android:layout_marginTop="2dp"/>
        </LinearLayout>

        <!-- Messages -->
        <LinearLayout
            android:id="@+id/navMessages"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackgroundBorderless">

            <ImageView
                android:id="@+id/navIconMessages"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_message"
                app:tint="#717171"
                android:contentDescription="Messages"/>

            <TextView
                android:id="@+id/navLabelMessages"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Messages"
                android:textSize="11sp"
                android:textColor="#717171"
                android:layout_marginTop="2dp"/>
        </LinearLayout>

        <!-- Profile -->
        <LinearLayout
            android:id="@+id/navProfile"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackgroundBorderless">

            <FrameLayout
                android:layout_width="24dp"
                android:layout_height="24dp">

                <ImageView
                    android:id="@+id/navIconProfile"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:src="@drawable/ic_profile"
                    android:contentDescription="Profile"/>

                <TextView
                    android:id="@+id/navProfileInitial"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:textColor="@android:color/white"
                    android:textStyle="bold"
                    android:textSize="10sp"/>
            </FrameLayout>

            <TextView
                android:id="@+id/navLabelProfile"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Profile"
                android:textSize="11sp"
                android:textColor="#717171"
                android:layout_marginTop="2dp"/>
        </LinearLayout>

    </LinearLayout>

    <!-- ===================================================== -->
    <!-- HOST BOTTOM NAV (GONE by default, shown in host mode) -->
    <!-- ===================================================== -->
    <LinearLayout
        android:id="@+id/navBarHost"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:minHeight="72dp"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingTop="6dp"
        android:paddingBottom="10dp"
        android:background="@drawable/bg_bottom_nav"
        android:elevation="8dp"
        android:weightSum="5"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/guidelineBottomNav"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Today -->
        <LinearLayout
            android:id="@+id/navToday"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackgroundBorderless">

            <ImageView
                android:id="@+id/navIconToday"
                android:layout_width="48dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_today"
                app:tint="#FF385C"
                android:contentDescription="Today"/>

            <TextView
                android:id="@+id/navLabelToday"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Today"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="#FF385C"
                android:layout_marginTop="2dp"/>
        </LinearLayout>

        <!-- Calendar -->
        <LinearLayout
            android:id="@+id/navCalendar"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackgroundBorderless">

            <ImageView
                android:id="@+id/navIconCalendar"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_calendar"
                app:tint="#717171"
                android:contentDescription="Calendar"/>

            <TextView
                android:id="@+id/navLabelCalendar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Calendar"
                android:textSize="11sp"
                android:textColor="#717171"
                android:layout_marginTop="2dp"/>
        </LinearLayout>

        <!-- Listings -->
        <LinearLayout
            android:id="@+id/navListings"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackgroundBorderless">

            <ImageView
                android:id="@+id/navIconListings"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_home"
                app:tint="#717171"
                android:contentDescription="Listings"/>

            <TextView
                android:id="@+id/navLabelListings"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Listings"
                android:textSize="11sp"
                android:textColor="#717171"
                android:layout_marginTop="2dp"/>
        </LinearLayout>

        <!-- Messages (host side — shared fragment) -->
        <LinearLayout
            android:id="@+id/navHostMessages"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackgroundBorderless">

            <ImageView
                android:id="@+id/navIconHostMessages"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_message"
                app:tint="#717171"
                android:contentDescription="Messages"/>

            <TextView
                android:id="@+id/navLabelHostMessages"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Messages"
                android:textSize="11sp"
                android:textColor="#717171"
                android:layout_marginTop="2dp"/>
        </LinearLayout>

        <!-- Profile (host side — shared fragment) -->
        <LinearLayout
            android:id="@+id/navHostProfile"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackgroundBorderless">

            <FrameLayout
                android:layout_width="24dp"
                android:layout_height="24dp">

                <ImageView
                    android:id="@+id/navIconHostProfile"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:src="@drawable/ic_profile"
                    android:contentDescription="Profile"/>

                <TextView
                    android:id="@+id/navHostProfileInitial"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:textColor="@android:color/white"
                    android:textStyle="bold"
                    android:textSize="10sp"/>
            </FrameLayout>

            <TextView
                android:id="@+id/navLabelHostProfile"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Profile"
                android:textSize="11sp"
                android:textColor="#717171"
                android:layout_marginTop="2dp"/>
        </LinearLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
