<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:fillViewport="true"
    android:background="@drawable/bg_auth_sheet">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingTop="12dp"
        android:paddingBottom="32dp"
        android:animateLayoutChanges="true">

        <!-- Drag Handle -->
        <View
            android:layout_width="40dp"
            android:layout_height="4dp"
            android:layout_gravity="center"
            android:layout_marginBottom="16dp"
            android:background="@drawable/bg_drag_handle" />

        <!-- Close -->
        <ImageView
            android:id="@+id/btnGuestDismiss"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_close"
            app:tint="#222222" />

        <!-- Logo -->
        <ImageView
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_gravity="center"
            android:layout_marginTop="20dp"
            android:src="@drawable/ic_airbnb" />

        <!-- Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="24dp"
            android:text="Log in"
            android:textColor="#111111"
            android:textSize="28sp"
            android:fontFamily="@font/poppins_bold" />

        <!-- Subtitle -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="8dp"
            android:text="Welcome back to Airbnb"
            android:textColor="#777777"
            android:textSize="14sp"
            android:fontFamily="@font/poppins_regular" />

        <!-- Email Input -->
        <EditText
            android:id="@+id/etEmail"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="32dp"
            android:background="@drawable/bg_input_outline"
            android:hint="Email"
            android:paddingHorizontal="16dp"
            android:textColor="#111111"
            android:textColorHint="#888888"
            android:textSize="15sp"
            android:fontFamily="@font/poppins_regular"
            android:inputType="textEmailAddress"
            android:importantForAutofill="yes" />

        <!-- Password Input -->
        <EditText
            android:id="@+id/etPassword"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_input_outline"
            android:hint="Password"
            android:paddingHorizontal="16dp"
            android:textColor="#111111"
            android:textColorHint="#888888"
            android:textSize="15sp"
            android:fontFamily="@font/poppins_regular"
            android:inputType="textPassword"
            android:importantForAutofill="yes" />

        <!-- Continue Button -->
        <Button
            android:id="@+id/btnContinue"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="20dp"
            android:background="@drawable/bg_button_airbnb"
            android:text="Continue"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:fontFamily="@font/poppins_bold"
            app:backgroundTint="@null" />

        <!-- Sign Up Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSignup"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="12dp"
            android:text="Create account"
            android:textAllCaps="false"
            android:textColor="#111111"
            android:textSize="16sp"
            android:fontFamily="@font/poppins_medium"
            android:backgroundTint="#FFFFFF"
            app:strokeColor="#DDDDDD"
            app:strokeWidth="1dp"
            app:cornerRadius="12dp" />

        <!-- Divider -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1"
                android:background="#DDDDDD" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="12dp"
                android:text="or"
                android:textColor="#888888"
                android:textSize="14sp" />

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1"
                android:background="#DDDDDD" />
        </LinearLayout>

        <!-- Social Buttons -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="24dp"
            android:orientation="horizontal">

            <!-- Google -->
            <ImageButton
                android:id="@+id/btnGuestLogIn"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:layout_marginEnd="12dp"
                android:background="@drawable/bg_social_button"
                android:padding="16dp"
                android:scaleType="centerInside"
                android:src="@drawable/ic_google"
                app:tint="@null" />

            <!-- Apple -->
            <ImageButton
                android:id="@+id/btnApple"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:background="@drawable/bg_social_button"
                android:padding="16dp"
                android:scaleType="centerInside"
                android:src="@drawable/ic_apple_vector"
                app:tint="#000000" />
        </LinearLayout>

        <!-- Use Another Account -->
        <TextView
            android:id="@+id/tvUseAnotherAccount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="18dp"
            android:text="Use another Google account"
            android:textColor="#FF385C"
            android:textSize="15sp"
            android:fontFamily="@font/poppins_medium"
            android:padding="8dp"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground" />


    </LinearLayout>

</ScrollView>