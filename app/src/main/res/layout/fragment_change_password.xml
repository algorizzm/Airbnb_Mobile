<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212">

    <!-- ── Top bar ── -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:background="#121212">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_chevron_left"
            android:padding="6dp"
            android:contentDescription="Back" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Change Password"
            android:textColor="@android:color/white"
            android:textSize="17sp"
            android:textStyle="bold"
            android:fontFamily="@font/poppins_bold"
            android:gravity="center" />

        <!-- Spacer to balance the back arrow -->
        <View
            android:layout_width="36dp"
            android:layout_height="36dp" />

    </LinearLayout>

    <!-- ── Scrollable content ── -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="56dp"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingTop="12dp">

            <!-- ── Shield hero illustration ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:paddingVertical="28dp">

                <!-- Shield icon in a dark circle -->
                <FrameLayout
                    android:layout_width="100dp"
                    android:layout_height="100dp">

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_translucent_circle" />

                    <ImageView
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_shield_lock"
                        android:contentDescription="Security shield" />

                </FrameLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="Secure Your Account"
                    android:textColor="@android:color/white"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/poppins_bold"
                    android:gravity="center" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="Choose a strong password and don't share it."
                    android:textColor="#80FFFFFF"
                    android:textSize="13sp"
                    android:fontFamily="@font/poppins_regular"
                    android:gravity="center" />

            </LinearLayout>

            <!-- ── Current Password ── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Current Password"
                android:textColor="@android:color/white"
                android:textSize="13sp"
                android:textStyle="bold"
                android:fontFamily="@font/poppins_bold"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_input_dark"
                android:paddingHorizontal="14dp"
                android:layout_marginBottom="16dp">

                <EditText
                    android:id="@+id/etCurrentPassword"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@null"
                    android:hint="Enter your current password"
                    android:textColor="@android:color/white"
                    android:textColorHint="#60FFFFFF"
                    android:textSize="14sp"
                    android:fontFamily="@font/poppins_regular"
                    android:inputType="textPassword"
                    android:singleLine="true" />

                <ImageView
                    android:id="@+id/toggleCurrentPassword"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_eye_closed"
                    android:alpha="0.6"
                    android:contentDescription="Toggle password visibility"
                    android:clickable="true"
                    android:focusable="true" />

            </LinearLayout>

            <!-- ── New Password ── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="New Password"
                android:textColor="@android:color/white"
                android:textSize="13sp"
                android:textStyle="bold"
                android:fontFamily="@font/poppins_bold"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_input_dark"
                android:paddingHorizontal="14dp">

                <EditText
                    android:id="@+id/etNewPassword"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@null"
                    android:hint="Enter your new password"
                    android:textColor="@android:color/white"
                    android:textColorHint="#60FFFFFF"
                    android:textSize="14sp"
                    android:fontFamily="@font/poppins_regular"
                    android:inputType="textPassword"
                    android:singleLine="true" />

                <ImageView
                    android:id="@+id/toggleNewPassword"
                    android:layout_width="22dp"
                    android:layout_height="wrap_content"
                    android:alpha="0.6"
                    android:clickable="true"
                    android:contentDescription="Toggle password visibility"
                    android:focusable="true"
                    android:src="@drawable/ic_eye_closed" />

            </LinearLayout>

            <!-- Password strength bar -->
            <ProgressBar
                android:id="@+id/passwordStrengthBar"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="4dp"
                android:layout_marginTop="8dp"
                android:max="100"
                android:progress="25"
                android:progressTint="#E53935"
                android:progressBackgroundTint="#2A2A2A" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:fontFamily="@font/poppins_bold"
                android:text="Confirm New Password"
                android:textColor="@android:color/white"
                android:textSize="13sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Password Strength:"
                    android:textColor="#80FFFFFF"
                    android:textSize="11sp"
                    android:fontFamily="@font/poppins_regular" />

                <TextView
                    android:id="@+id/tvPasswordStrength"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Weak"
                    android:textColor="#E53935"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/poppins_bold" />

            </LinearLayout>

            <!-- ── Confirm New Password ── -->

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_input_dark"
                android:paddingHorizontal="14dp"
                android:layout_marginBottom="20dp">

                <EditText
                    android:id="@+id/etConfirmPassword"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@null"
                    android:hint="Confirm your new password"
                    android:textColor="@android:color/white"
                    android:textColorHint="#60FFFFFF"
                    android:textSize="14sp"
                    android:fontFamily="@font/poppins_regular"
                    android:inputType="textPassword"
                    android:singleLine="true" />

                <ImageView
                    android:id="@+id/toggleConfirmPassword"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_eye_closed"
                    android:alpha="0.6"
                    android:contentDescription="Toggle password visibility"
                    android:clickable="true"
                    android:focusable="true" />

            </LinearLayout>

            <!-- ── Password requirements card ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_dark_card"
                android:padding="14dp"
                android:layout_marginBottom="28dp">

                <ImageView
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:src="@drawable/ic_shield_lock"
                    android:layout_marginEnd="12dp"
                    android:contentDescription="Requirements" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Password must contain:"
                        android:textColor="@android:color/white"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:fontFamily="@font/poppins_bold"
                        android:layout_marginBottom="6dp" />

                    <!-- Requirement: 8+ characters -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <ImageView
                            android:id="@+id/icReq1"
                            android:layout_width="14dp"
                            android:layout_height="14dp"
                            android:src="@drawable/ic_check_circle"
                            android:layout_marginEnd="6dp"
                            android:alpha="0.4"
                            android:contentDescription="Requirement 1" />

                        <TextView
                            android:id="@+id/tvReq1"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="At least 8 characters"
                            android:textColor="#80FFFFFF"
                            android:textSize="11sp"
                            android:fontFamily="@font/poppins_regular" />

                    </LinearLayout>

                    <!-- Requirement: uppercase -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="4dp">

                        <ImageView
                            android:id="@+id/icReq2"
                            android:layout_width="14dp"
                            android:layout_height="14dp"
                            android:src="@drawable/ic_check_circle"
                            android:layout_marginEnd="6dp"
                            android:alpha="0.4"
                            android:contentDescription="Requirement 2" />

                        <TextView
                            android:id="@+id/tvReq2"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="One uppercase letter (A–Z)"
                            android:textColor="#80FFFFFF"
                            android:textSize="11sp"
                            android:fontFamily="@font/poppins_regular" />

                    </LinearLayout>

                    <!-- Requirement: number -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="4dp">

                        <ImageView
                            android:id="@+id/icReq3"
                            android:layout_width="14dp"
                            android:layout_height="14dp"
                            android:src="@drawable/ic_check_circle"
                            android:layout_marginEnd="6dp"
                            android:alpha="0.4"
                            android:contentDescription="Requirement 3" />

                        <TextView
                            android:id="@+id/tvReq3"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="One number (0–9)"
                            android:textColor="#80FFFFFF"
                            android:textSize="11sp"
                            android:fontFamily="@font/poppins_regular" />

                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>

            <!-- Save Changes button inside scroll -->
            <Button
                android:id="@+id/btnSaveChanges"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginHorizontal="0dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="24dp"
                android:background="@drawable/bg_button_green"
                android:text="Save Changes"
                android:textAllCaps="false"
                android:textColor="@android:color/black"
                android:textSize="15sp"
                android:textStyle="bold"
                android:fontFamily="@font/poppins_bold"
                app:backgroundTint="@null" />

        </LinearLayout>

    </ScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
