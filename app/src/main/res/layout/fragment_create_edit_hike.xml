<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212"
    android:orientation="vertical">

    <!-- Top bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingTop="44dp"
        android:paddingBottom="12dp"
        android:paddingStart="4dp"
        android:paddingEnd="16dp">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@null"
            android:src="@drawable/ic_chevron_left"
            android:tint="#FFFFFF"
            android:contentDescription="Back"
            android:padding="12dp" />

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Create Hike"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:fontFamily="@font/poppins_bold" />

    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Title -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Title"
                android:textColor="#80FFFFFF"
                android:textSize="12sp"
                android:fontFamily="@font/poppins_regular"
                android:layout_marginBottom="4dp" />

            <EditText
                android:id="@+id/etTitle"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/bg_edittext_border"
                android:inputType="textCapWords"
                android:textColor="#FFFFFF"
                android:textColorHint="#666666"
                android:hint="Enter title"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:fontFamily="@font/poppins_regular" />

            <!-- Description -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Description"
                android:textColor="#80FFFFFF"
                android:textSize="12sp"
                android:fontFamily="@font/poppins_regular"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="4dp" />

            <EditText
                android:id="@+id/etDescription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_edittext_border"
                android:gravity="top"
                android:inputType="textMultiLine"
                android:minLines="3"
                android:textColor="#FFFFFF"
                android:textColorHint="#666666"
                android:hint="Enter description"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="12dp"
                android:paddingBottom="12dp"
                android:fontFamily="@font/poppins_regular" />

            <!-- Location -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Location"
                android:textColor="#80FFFFFF"
                android:textSize="12sp"
                android:fontFamily="@font/poppins_regular"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="4dp" />

            <EditText
                android:id="@+id/etLocation"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/bg_edittext_border"
                android:inputType="text"
                android:textColor="#FFFFFF"
                android:textColorHint="#666666"
                android:hint="Enter location"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:fontFamily="@font/poppins_regular" />

            <!-- Difficulty -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Difficulty"
                android:textColor="#80FFFFFF"
                android:textSize="12sp"
                android:fontFamily="@font/poppins_regular"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="4dp" />

            <EditText
                android:id="@+id/etDifficulty"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/bg_edittext_border"
                android:inputType="text"
                android:textColor="#FFFFFF"
                android:textColorHint="#666666"
                android:hint="e.g. Easy, Moderate, Hard"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:fontFamily="@font/poppins_regular" />

            <!-- Distance -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Distance (km)"
                android:textColor="#80FFFFFF"
                android:textSize="12sp"
                android:fontFamily="@font/poppins_regular"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="4dp" />

            <EditText
                android:id="@+id/etDistanceKm"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/bg_edittext_border"
                android:inputType="numberDecimal"
                android:textColor="#FFFFFF"
                android:textColorHint="#666666"
                android:hint="0.0"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:fontFamily="@font/poppins_regular" />

            <!-- Price -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Price"
                android:textColor="#80FFFFFF"
                android:textSize="12sp"
                android:fontFamily="@font/poppins_regular"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="4dp" />

            <EditText
                android:id="@+id/etPrice"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/bg_edittext_border"
                android:inputType="numberDecimal"
                android:textColor="#FFFFFF"
                android:textColorHint="#666666"
                android:hint="0.00"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:fontFamily="@font/poppins_regular" />

            <!-- Duration -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Duration (hours)"
                android:textColor="#80FFFFFF"
                android:textSize="12sp"
                android:fontFamily="@font/poppins_regular"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="4dp" />

            <EditText
                android:id="@+id/etDurationHours"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/bg_edittext_border"
                android:inputType="numberDecimal"
                android:textColor="#FFFFFF"
                android:textColorHint="#666666"
                android:hint="0.0"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:fontFamily="@font/poppins_regular" />

            <!-- Max Participants -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Max Participants"
                android:textColor="#80FFFFFF"
                android:textSize="12sp"
                android:fontFamily="@font/poppins_regular"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="4dp" />

            <EditText
                android:id="@+id/etMaxParticipants"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/bg_edittext_border"
                android:inputType="number"
                android:textColor="#FFFFFF"
                android:textColorHint="#666666"
                android:hint="0"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:fontFamily="@font/poppins_regular" />

            <!-- Status -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Status"
                android:textColor="#80FFFFFF"
                android:textSize="12sp"
                android:fontFamily="@font/poppins_regular"
                android:layout_marginBottom="4dp" />

            <Spinner
                android:id="@+id/spinnerStatus"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/bg_edittext_border"
                android:backgroundTint="#02D083"
                android:popupBackground="#1A1A1A" />

            <!-- Hike Image -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Hike Image"
                android:textColor="#80FFFFFF"
                android:textSize="12sp"
                android:fontFamily="@font/poppins_regular"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="4dp" />

            <ImageView
                android:id="@+id/imgHikePreview"
                android:layout_width="match_parent"
                android:layout_height="160dp"
                android:scaleType="centerCrop"
                android:src="@drawable/img_hike_placeholder"
                android:contentDescription="Hike image preview"
                android:visibility="gone" />

            <Button
                android:id="@+id/btnUploadImage"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="4dp"
                android:background="@drawable/bg_button_outline_green"
                android:text="Upload Image"
                android:textAllCaps="false"
                android:textColor="#02D083"
                android:fontFamily="@font/poppins_bold"
                app:backgroundTint="@null" />

            <!-- Save button -->
            <Button
                android:id="@+id/btnSave"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="20dp"
                android:background="@drawable/bg_button_green"
                android:text="Save"
                android:textAllCaps="false"
                android:textColor="#000000"
                android:fontFamily="@font/poppins_bold"
                app:backgroundTint="@null" />

            <!-- Delete button -->
            <Button
                android:id="@+id/btnDelete"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="24dp"
                android:background="@drawable/bg_button_outline_red"
                android:text="Delete Hike"
                android:textAllCaps="false"
                android:textColor="#FF4444"
                android:fontFamily="@font/poppins_bold"
                app:backgroundTint="@null"
                android:visibility="gone" />

        </LinearLayout>
    </ScrollView>

</LinearLayout>