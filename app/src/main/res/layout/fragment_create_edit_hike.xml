<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212"
    android:orientation="vertical">

    <!-- Top bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingTop="44dp"
        android:paddingBottom="12dp"
        android:paddingStart="4dp"
        android:paddingEnd="16dp">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@null"
            android:src="@drawable/ic_chevron_left"
            android:tint="#FFFFFF"
            android:contentDescription="Back"
            android:padding="12dp" />

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Create Hike"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:fontFamily="@font/poppins_bold" />

        <!-- Loading indicator in top bar -->
        <ProgressBar
            android:id="@+id/progressSaving"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:indeterminateTint="#02D083"
            android:visibility="gone" />

    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ── Hero image picker ── -->
            <FrameLayout
                android:id="@+id/imgPickerArea"
                android:layout_width="match_parent"
                android:layout_height="200dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground">

                <ImageView
                    android:id="@+id/imgHikePreview"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:src="@drawable/img_hike_placeholder"
                    android:contentDescription="Hike cover photo" />

                <!-- Dark overlay -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="#66000000" />

                <!-- Camera icon + label centred -->
                <LinearLayout
                    android:id="@+id/layoutImageHint"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:orientation="vertical"
                    android:gravity="center">

                    <ImageView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:src="@drawable/ic_camera"
                        android:tint="#FFFFFF"
                        android:contentDescription="Upload photo" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="Tap to add cover photo"
                        android:textColor="#CCFFFFFF"
                        android:textSize="13sp"
                        android:fontFamily="@font/poppins_medium" />

                </LinearLayout>

                <!-- Upload progress overlay -->
                <ProgressBar
                    android:id="@+id/progressImage"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_gravity="center"
                    android:indeterminateTint="#02D083"
                    android:visibility="gone" />

            </FrameLayout>

            <!-- ── Form fields ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Title -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Hike Title *"
                    android:textColor="#80FFFFFF"
                    android:textSize="12sp"
                    android:fontFamily="@font/poppins_medium"
                    android:layout_marginBottom="4dp" />

                <EditText
                    android:id="@+id/etTitle"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:background="@drawable/bg_edittext_border"
                    android:inputType="textCapWords"
                    android:textColor="#FFFFFF"
                    android:textColorHint="#555555"
                    android:hint="e.g. Mt. Apo Sunrise Trek"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:fontFamily="@font/poppins_regular" />

                <!-- Description -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Description"
                    android:textColor="#80FFFFFF"
                    android:textSize="12sp"
                    android:fontFamily="@font/poppins_medium"
                    android:layout_marginTop="14dp"
                    android:layout_marginBottom="4dp" />

                <EditText
                    android:id="@+id/etDescription"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_edittext_border"
                    android:gravity="top"
                    android:inputType="textMultiLine"
                    android:minLines="3"
                    android:maxLines="6"
                    android:textColor="#FFFFFF"
                    android:textColorHint="#555555"
                    android:hint="Describe the trail, highlights, what to bring…"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:paddingTop="12dp"
                    android:paddingBottom="12dp"
                    android:fontFamily="@font/poppins_regular" />

                <!-- Location -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Location *"
                    android:textColor="#80FFFFFF"
                    android:textSize="12sp"
                    android:fontFamily="@font/poppins_medium"
                    android:layout_marginTop="14dp"
                    android:layout_marginBottom="4dp" />

                <EditText
                    android:id="@+id/etLocation"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:background="@drawable/bg_edittext_border"
                    android:inputType="text"
                    android:textColor="#FFFFFF"
                    android:textColorHint="#555555"
                    android:hint="e.g. Davao del Sur, Philippines"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:fontFamily="@font/poppins_regular" />

                <!-- Difficulty chips -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Difficulty"
                    android:textColor="#80FFFFFF"
                    android:textSize="12sp"
                    android:fontFamily="@font/poppins_medium"
                    android:layout_marginTop="14dp"
                    android:layout_marginBottom="8dp" />

                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/chipGroupDifficulty"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:singleSelection="true"
                    app:selectionRequired="true">

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipEasy"
                        style="@style/Widget.MaterialComponents.Chip.Choice"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Easy"
                        android:textColor="#FFFFFF"
                        android:fontFamily="@font/poppins_medium"
                        app:chipBackgroundColor="@color/chip_state_color"
                        app:chipStrokeColor="#02D083"
                        app:chipStrokeWidth="1dp"
                        app:checkedIconTint="#000000" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipModerate"
                        style="@style/Widget.MaterialComponents.Chip.Choice"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Moderate"
                        android:textColor="#FFFFFF"
                        android:fontFamily="@font/poppins_medium"
                        android:checked="true"
                        app:chipBackgroundColor="@color/chip_state_color"
                        app:chipStrokeColor="#02D083"
                        app:chipStrokeWidth="1dp"
                        app:checkedIconTint="#000000" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipHard"
                        style="@style/Widget.MaterialComponents.Chip.Choice"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Hard"
                        android:textColor="#FFFFFF"
                        android:fontFamily="@font/poppins_medium"
                        app:chipBackgroundColor="@color/chip_state_color"
                        app:chipStrokeColor="#02D083"
                        app:chipStrokeWidth="1dp"
                        app:checkedIconTint="#000000" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipExpert"
                        style="@style/Widget.MaterialComponents.Chip.Choice"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Expert"
                        android:textColor="#FFFFFF"
                        android:fontFamily="@font/poppins_medium"
                        app:chipBackgroundColor="@color/chip_state_color"
                        app:chipStrokeColor="#02D083"
                        app:chipStrokeWidth="1dp"
                        app:checkedIconTint="#000000" />

                </com.google.android.material.chip.ChipGroup>

                <!-- Distance + Duration row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="14dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginEnd="8dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Distance *"
                            android:textColor="#80FFFFFF"
                            android:textSize="12sp"
                            android:fontFamily="@font/poppins_medium"
                            android:layout_marginBottom="4dp" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="52dp"
                            android:orientation="horizontal"
                            android:background="@drawable/bg_edittext_border"
                            android:gravity="center_vertical">

                            <EditText
                                android:id="@+id/etDistanceKm"
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_weight="1"
                                android:background="@null"
                                android:inputType="numberDecimal"
                                android:textColor="#FFFFFF"
                                android:textColorHint="#555555"
                                android:hint="0.0"
                                android:paddingStart="16dp"
                                android:fontFamily="@font/poppins_regular" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="km"
                                android:textColor="#80FFFFFF"
                                android:textSize="12sp"
                                android:paddingEnd="12dp"
                                android:fontFamily="@font/poppins_medium" />

                        </LinearLayout>

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Duration"
                            android:textColor="#80FFFFFF"
                            android:textSize="12sp"
                            android:fontFamily="@font/poppins_medium"
                            android:layout_marginBottom="4dp" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="52dp"
                            android:orientation="horizontal"
                            android:background="@drawable/bg_edittext_border"
                            android:gravity="center_vertical">

                            <EditText
                                android:id="@+id/etDurationHours"
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_weight="1"
                                android:background="@null"
                                android:inputType="numberDecimal"
                                android:textColor="#FFFFFF"
                                android:textColorHint="#555555"
                                android:hint="0"
                                android:paddingStart="16dp"
                                android:fontFamily="@font/poppins_regular" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="hrs"
                                android:textColor="#80FFFFFF"
                                android:textSize="12sp"
                                android:paddingEnd="12dp"
                                android:fontFamily="@font/poppins_medium" />

                        </LinearLayout>

                    </LinearLayout>

                </LinearLayout>

                <!-- Price + Max Participants row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="14dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginEnd="8dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Price *"
                            android:textColor="#80FFFFFF"
                            android:textSize="12sp"
                            android:fontFamily="@font/poppins_medium"
                            android:layout_marginBottom="4dp" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="52dp"
                            android:orientation="horizontal"
                            android:background="@drawable/bg_edittext_border"
                            android:gravity="center_vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="₱"
                                android:textColor="#02D083"
                                android:textSize="14sp"
                                android:paddingStart="12dp"
                                android:fontFamily="@font/poppins_bold" />

                            <EditText
                                android:id="@+id/etPrice"
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_weight="1"
                                android:background="@null"
                                android:inputType="numberDecimal"
                                android:textColor="#FFFFFF"
                                android:textColorHint="#555555"
                                android:hint="0.00"
                                android:paddingStart="8dp"
                                android:paddingEnd="12dp"
                                android:fontFamily="@font/poppins_regular" />

                        </LinearLayout>

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Max Slots *"
                            android:textColor="#80FFFFFF"
                            android:textSize="12sp"
                            android:fontFamily="@font/poppins_medium"
                            android:layout_marginBottom="4dp" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="52dp"
                            android:orientation="horizontal"
                            android:background="@drawable/bg_edittext_border"
                            android:gravity="center_vertical">

                            <EditText
                                android:id="@+id/etMaxParticipants"
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_weight="1"
                                android:background="@null"
                                android:inputType="number"
                                android:textColor="#FFFFFF"
                                android:textColorHint="#555555"
                                android:hint="0"
                                android:paddingStart="16dp"
                                android:fontFamily="@font/poppins_regular" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="pax"
                                android:textColor="#80FFFFFF"
                                android:textSize="12sp"
                                android:paddingEnd="12dp"
                                android:fontFamily="@font/poppins_medium" />

                        </LinearLayout>

                    </LinearLayout>

                </LinearLayout>

                <!-- Status toggle chips -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Status"
                    android:textColor="#80FFFFFF"
                    android:textSize="12sp"
                    android:fontFamily="@font/poppins_medium"
                    android:layout_marginTop="14dp"
                    android:layout_marginBottom="8dp" />

                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/chipGroupStatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:singleSelection="true"
                    app:selectionRequired="true">

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipOpen"
                        style="@style/Widget.MaterialComponents.Chip.Choice"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Open"
                        android:textColor="#FFFFFF"
                        android:fontFamily="@font/poppins_medium"
                        android:checked="true"
                        app:chipBackgroundColor="@color/chip_state_color"
                        app:chipStrokeColor="#02D083"
                        app:chipStrokeWidth="1dp"
                        app:checkedIconTint="#000000" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipClosed"
                        style="@style/Widget.MaterialComponents.Chip.Choice"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Closed"
                        android:textColor="#FFFFFF"
                        android:fontFamily="@font/poppins_medium"
                        app:chipBackgroundColor="@color/chip_state_color"
                        app:chipStrokeColor="#02D083"
                        app:chipStrokeWidth="1dp"
                        app:checkedIconTint="#000000" />

                </com.google.android.material.chip.ChipGroup>

                <!-- Hidden EditText kept for ViewModel compatibility -->
                <EditText
                    android:id="@+id/etDifficulty"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:visibility="gone" />

                <Spinner
                    android:id="@+id/spinnerStatus"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:visibility="gone" />

                <!-- Save button -->
                <Button
                    android:id="@+id/btnSave"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="24dp"
                    android:background="@drawable/bg_button_green"
                    android:text="Publish Hike"
                    android:textAllCaps="false"
                    android:textColor="#000000"
                    android:textSize="15sp"
                    android:fontFamily="@font/poppins_bold"
                    app:backgroundTint="@null" />

                <!-- Delete button (edit mode only) -->
                <Button
                    android:id="@+id/btnDelete"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="32dp"
                    android:background="@drawable/bg_button_outline_red"
                    android:text="Delete Hike"
                    android:textAllCaps="false"
                    android:textColor="#FF4444"
                    android:fontFamily="@font/poppins_bold"
                    app:backgroundTint="@null"
                    android:visibility="gone" />

                <!-- Hidden upload button kept for ViewModel compatibility -->
                <Button
                    android:id="@+id/btnUploadImage"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:visibility="gone" />

            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</LinearLayout>
