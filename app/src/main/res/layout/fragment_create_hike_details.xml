<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212"
    android:fillViewport="true"
    android:clipToPadding="false">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- HEADER -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingTop="24dp"
            android:paddingEnd="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Create Hike"
                android:textColor="#FFFFFF"
                android:textSize="24sp"
                android:fontFamily="@font/poppins_bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Step 1 of 6"
                android:textColor="#80FFFFFF"
                android:textSize="13sp"
                android:fontFamily="@font/poppins_regular" />

            <!-- STEP PROGRESS BAR -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="8dp"
                android:layout_marginTop="18dp"
                android:orientation="horizontal">

                <View
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_marginEnd="4dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_progress_active" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginStart="2dp"
                    android:layout_marginEnd="4dp"
                    android:background="@drawable/bg_progress_inactive" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginStart="2dp"
                    android:layout_marginEnd="4dp"
                    android:background="@drawable/bg_progress_inactive" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginStart="2dp"
                    android:layout_marginEnd="4dp"
                    android:background="@drawable/bg_progress_inactive" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginStart="2dp"
                    android:layout_marginEnd="4dp"
                    android:background="@drawable/bg_progress_inactive" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginStart="2dp"
                    android:background="@drawable/bg_progress_inactive" />

            </LinearLayout>

        </LinearLayout>

        <!-- FORM -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingTop="24dp"
            android:paddingEnd="20dp"
            android:paddingBottom="32dp">

            <!-- TITLE -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Hike Title *"
                android:textColor="#80FFFFFF"
                android:textSize="12sp"
                android:fontFamily="@font/poppins_medium"
                android:layout_marginBottom="6dp" />

            <EditText
                android:id="@+id/etTitle"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:background="@drawable/bg_edittext_border"
                android:hint="e.g. Osmeña Peak Sunrise Trek"
                android:inputType="textCapWords"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:textColor="#FFFFFF"
                android:textColorHint="#555555"
                android:textSize="14sp"
                android:fontFamily="@font/poppins_regular" />

            <!-- DESCRIPTION -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Description"
                android:textColor="#80FFFFFF"
                android:textSize="12sp"
                android:fontFamily="@font/poppins_medium"
                android:layout_marginTop="18dp"
                android:layout_marginBottom="6dp" />

            <EditText
                android:id="@+id/etDescription"
                android:layout_width="match_parent"
                android:layout_height="90dp"
                android:background="@drawable/bg_edittext_border"
                android:gravity="top"
                android:hint="Describe the hike..."
                android:inputType="textMultiLine"
                android:maxLines="3"
                android:paddingStart="16dp"
                android:paddingTop="14dp"
                android:paddingEnd="16dp"
                android:paddingBottom="14dp"
                android:textColor="#FFFFFF"
                android:textColorHint="#555555"
                android:textSize="14sp"
                android:fontFamily="@font/poppins_regular"
                android:scrollbars="vertical" />

            <!-- MAX SLOTS -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Max Slots *"
                android:textColor="#80FFFFFF"
                android:textSize="12sp"
                android:fontFamily="@font/poppins_medium"
                android:layout_marginTop="18dp"
                android:layout_marginBottom="6dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:background="@drawable/bg_edittext_border"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <EditText
                    android:id="@+id/etMaxSlots"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@null"
                    android:hint="e.g. 12"
                    android:inputType="number"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:textColor="#FFFFFF"
                    android:textColorHint="#555555"
                    android:textSize="14sp"
                    android:fontFamily="@font/poppins_regular" />

            </LinearLayout>

            <!-- TAGS -->
            <LinearLayout
                android:id="@+id/layoutTagsHeader"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="22dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Tags"
                    android:textColor="#80FFFFFF"
                    android:textSize="12sp"
                    android:fontFamily="@font/poppins_medium" />

                <TextView
                    android:id="@+id/tvToggleTags"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Show More"
                    android:textColor="#02D083"
                    android:textSize="12sp"
                    android:fontFamily="@font/poppins_bold" />

            </LinearLayout>

            <!-- PRIMARY TAGS -->
            <com.google.android.material.chip.ChipGroup
                android:id="@+id/chipGroupTagsPrimary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                app:singleLine="false">

                <com.google.android.material.chip.Chip
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    style="@style/Widget.MaterialComponents.Chip.Choice"
                    android:text="Sunrise"
                    android:textColor="#FFFFFF"
                    android:fontFamily="@font/poppins_medium"
                    app:chipBackgroundColor="@color/chip_state_color"
                    app:chipStrokeColor="#02D083"
                    app:chipStrokeWidth="1dp" />

                <com.google.android.material.chip.Chip
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    style="@style/Widget.MaterialComponents.Chip.Choice"
                    android:text="Camping"
                    android:textColor="#FFFFFF"
                    android:fontFamily="@font/poppins_medium"
                    app:chipBackgroundColor="@color/chip_state_color"
                    app:chipStrokeColor="#02D083"
                    app:chipStrokeWidth="1dp" />

                <com.google.android.material.chip.Chip
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    style="@style/Widget.MaterialComponents.Chip.Choice"
                    android:text="Day Hike"
                    android:textColor="#FFFFFF"
                    android:fontFamily="@font/poppins_medium"
                    app:chipBackgroundColor="@color/chip_state_color"
                    app:chipStrokeColor="#02D083"
                    app:chipStrokeWidth="1dp" />

            </com.google.android.material.chip.ChipGroup>

            <!-- EXPANDED TAGS -->
            <com.google.android.material.chip.ChipGroup
                android:id="@+id/chipGroupTagsExpanded"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:visibility="gone"
                app:singleLine="false">

                <com.google.android.material.chip.Chip
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    style="@style/Widget.MaterialComponents.Chip.Choice"
                    android:text="Waterfall"
                    android:textColor="#FFFFFF"
                    android:fontFamily="@font/poppins_medium"
                    app:chipBackgroundColor="@color/chip_state_color"
                    app:chipStrokeColor="#02D083"
                    app:chipStrokeWidth="1dp" />

                <com.google.android.material.chip.Chip
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    style="@style/Widget.MaterialComponents.Chip.Choice"
                    android:text="Beginner Friendly"
                    android:textColor="#FFFFFF"
                    android:fontFamily="@font/poppins_medium"
                    app:chipBackgroundColor="@color/chip_state_color"
                    app:chipStrokeColor="#02D083"
                    app:chipStrokeWidth="1dp" />

                <com.google.android.material.chip.Chip
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    style="@style/Widget.MaterialComponents.Chip.Choice"
                    android:text="Advanced"
                    android:textColor="#FFFFFF"
                    android:fontFamily="@font/poppins_medium"
                    app:chipBackgroundColor="@color/chip_state_color"
                    app:chipStrokeColor="#02D083"
                    app:chipStrokeWidth="1dp" />

                <com.google.android.material.chip.Chip
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    style="@style/Widget.MaterialComponents.Chip.Choice"
                    android:text="Overnight"
                    android:textColor="#FFFFFF"
                    android:fontFamily="@font/poppins_medium"
                    app:chipBackgroundColor="@color/chip_state_color"
                    app:chipStrokeColor="#02D083"
                    app:chipStrokeWidth="1dp" />

                <com.google.android.material.chip.Chip
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    style="@style/Widget.MaterialComponents.Chip.Choice"
                    android:text="Sea of Clouds"
                    android:textColor="#FFFFFF"
                    android:fontFamily="@font/poppins_medium"
                    app:chipBackgroundColor="@color/chip_state_color"
                    app:chipStrokeColor="#02D083"
                    app:chipStrokeWidth="1dp" />

                <com.google.android.material.chip.Chip
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    style="@style/Widget.MaterialComponents.Chip.Choice"
                    android:text="Forest Trail"
                    android:textColor="#FFFFFF"
                    android:fontFamily="@font/poppins_medium"
                    app:chipBackgroundColor="@color/chip_state_color"
                    app:chipStrokeColor="#02D083"
                    app:chipStrokeWidth="1dp" />

                <com.google.android.material.chip.Chip
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    style="@style/Widget.MaterialComponents.Chip.Choice"
                    android:text="River Crossing"
                    android:textColor="#FFFFFF"
                    android:fontFamily="@font/poppins_medium"
                    app:chipBackgroundColor="@color/chip_state_color"
                    app:chipStrokeColor="#02D083"
                    app:chipStrokeWidth="1dp" />

                <com.google.android.material.chip.Chip
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    style="@style/Widget.MaterialComponents.Chip.Choice"
                    android:text="Weekend Trip"
                    android:textColor="#FFFFFF"
                    android:fontFamily="@font/poppins_medium"
                    app:chipBackgroundColor="@color/chip_state_color"
                    app:chipStrokeColor="#02D083"
                    app:chipStrokeWidth="1dp" />

                <com.google.android.material.chip.Chip
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    style="@style/Widget.MaterialComponents.Chip.Choice"
                    android:text="Photo Spot"
                    android:textColor="#FFFFFF"
                    android:fontFamily="@font/poppins_medium"
                    app:chipBackgroundColor="@color/chip_state_color"
                    app:chipStrokeColor="#02D083"
                    app:chipStrokeWidth="1dp" />

            </com.google.android.material.chip.ChipGroup>

        </LinearLayout>

    </LinearLayout>

</ScrollView>