<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Price amount (PHP)"
            android:textColor="#FFFFFF" />

        <EditText
            android:id="@+id/etPrice"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="0"
            android:textColor="#FFFFFF"
            android:textColorHint="#888888"
            android:inputType="numberDecimal" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Payment methods (comma or newline)"
            android:textColor="#FFFFFF" />

        <EditText
            android:id="@+id/etPaymentMethods"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="GCash, Bank Transfer, Cash Meetup"
            android:textColor="#FFFFFF"
            android:textColorHint="#888888"
            android:inputType="textMultiLine"
            android:minLines="2" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Pricing notes"
            android:textColor="#FFFFFF" />

        <EditText
            android:id="@+id/etPricingNotes"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Optional"
            android:textColor="#FFFFFF"
            android:textColorHint="#888888"
            android:inputType="textMultiLine"
            android:minLines="2" />
    </LinearLayout>
</ScrollView>
