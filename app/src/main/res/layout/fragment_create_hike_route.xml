<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#121212"
        android:fillViewport="true"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

        <!-- HEADER -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingTop="24dp"
            android:paddingEnd="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Create Hike Route"
                android:textColor="#FFFFFF"
                android:textSize="24sp"
                android:fontFamily="@font/poppins_bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Step 3 of 6"
                android:textColor="#80FFFFFF"
                android:textSize="13sp"
                android:fontFamily="@font/poppins_regular" />

            <!-- STEP PROGRESS -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="8dp"
                android:layout_marginTop="18dp"
                android:orientation="horizontal">

                <View
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginEnd="4dp"
                    android:background="@drawable/bg_progress_active" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginStart="2dp"
                    android:layout_marginEnd="4dp"
                    android:background="@drawable/bg_progress_active" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginStart="2dp"
                    android:layout_marginEnd="4dp"
                    android:background="@drawable/bg_progress_active" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginStart="2dp"
                    android:layout_marginEnd="4dp"
                    android:background="@drawable/bg_progress_inactive" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginStart="2dp"
                    android:layout_marginEnd="4dp"
                    android:background="@drawable/bg_progress_inactive" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginStart="2dp"
                    android:background="@drawable/bg_progress_inactive" />

            </LinearLayout>

        </LinearLayout>

        <!-- FORM -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingTop="24dp"
            android:paddingEnd="20dp"
            android:paddingBottom="32dp">

            <!-- Meetup Point -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Meetup Point"
                android:textColor="#80FFFFFF"
                android:textSize="12sp"
                android:fontFamily="@font/poppins_medium"
                android:layout_marginBottom="6dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <EditText
                    android:id="@+id/etMeetup"
                    android:layout_width="0dp"
                    android:layout_height="54dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_edittext_border"
                    android:hint="Where to meet"
                    android:inputType="textCapWords"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:textColor="#FFFFFF"
                    android:textColorHint="#555555"
                    android:textSize="14sp"
                    android:fontFamily="@font/poppins_regular" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnUseCurrentLocation"
                    android:layout_width="wrap_content"
                    android:layout_height="54dp"
                    android:layout_marginStart="10dp"
                    android:text="GPS"
                    android:textAllCaps="false"
                    android:textColor="#FFFFFF"
                    android:fontFamily="@font/poppins_medium"
                    app:backgroundTint="#02D083"
                    app:cornerRadius="14dp"
                    app:icon="@android:drawable/ic_menu_mylocation"
                    app:iconGravity="textStart"
                    app:iconTint="#FFFFFF" />

            </LinearLayout>

            <!-- Destination -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Destination"
                android:textColor="#80FFFFFF"
                android:textSize="12sp"
                android:fontFamily="@font/poppins_medium"
                android:layout_marginTop="18dp"
                android:layout_marginBottom="6dp" />

            <EditText
                android:id="@+id/etDestination"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:background="@drawable/bg_edittext_border"
                android:hint="Summit / trail end"
                android:inputType="textCapWords"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:textColor="#FFFFFF"
                android:textColorHint="#555555"
                android:textSize="14sp"
                android:fontFamily="@font/poppins_regular" />

            <!-- Difficulty -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Difficulty"
                android:textColor="#80FFFFFF"
                android:textSize="12sp"
                android:fontFamily="@font/poppins_medium"
                android:layout_marginTop="22dp"
                android:layout_marginBottom="8dp" />

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/chipGroupDifficulty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:singleSelection="true"
                app:selectionRequired="true">

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipBeginner"
                    style="@style/Widget.MaterialComponents.Chip.Choice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Beginner"
                    android:textColor="#FFFFFF"
                    android:checked="true"
                    android:fontFamily="@font/poppins_medium"
                    app:chipBackgroundColor="@color/chip_state_color"
                    app:chipStrokeColor="#02D083"
                    app:chipStrokeWidth="1dp" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipIntermediate"
                    style="@style/Widget.MaterialComponents.Chip.Choice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Intermediate"
                    android:textColor="#FFFFFF"
                    android:fontFamily="@font/poppins_medium"
                    app:chipBackgroundColor="@color/chip_state_color"
                    app:chipStrokeColor="#02D083"
                    app:chipStrokeWidth="1dp" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipAdvanced"
                    style="@style/Widget.MaterialComponents.Chip.Choice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Advanced"
                    android:textColor="#FFFFFF"
                    android:fontFamily="@font/poppins_medium"
                    app:chipBackgroundColor="@color/chip_state_color"
                    app:chipStrokeColor="#02D083"
                    app:chipStrokeWidth="1dp" />

            </com.google.android.material.chip.ChipGroup>

            <!-- Elevation -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Elevation (meters)"
                android:textColor="#80FFFFFF"
                android:textSize="12sp"
                android:fontFamily="@font/poppins_medium"
                android:layout_marginTop="22dp"
                android:layout_marginBottom="6dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_dark_card"
                android:paddingHorizontal="16dp"
                android:layout_marginBottom="10dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Elevation"
                    android:textColor="@android:color/white"
                    android:textSize="14sp"
                    android:fontFamily="@font/poppins_regular" />

                <TextView
                    android:id="@+id/btnElevationDecrement"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:background="@drawable/bg_counter_btn"
                    android:text="&#8722;"
                    android:textColor="@android:color/white"
                    android:textSize="18sp"
                    android:gravity="center"
                    android:clickable="true"
                    android:focusable="true"
                    android:contentDescription="Decrease elevation" />

                <TextView
                    android:id="@+id/tvElevationValue"
                    android:layout_width="60dp"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="@android:color/white"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/poppins_bold"
                    android:gravity="center" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="m"
                    android:textColor="#80FFFFFF"
                    android:textSize="12sp"
                    android:layout_marginEnd="8dp"
                    android:fontFamily="@font/poppins_medium" />

                <TextView
                    android:id="@+id/btnElevationIncrement"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:background="@drawable/bg_counter_btn"
                    android:text="+"
                    android:textColor="@android:color/white"
                    android:textSize="18sp"
                    android:gravity="center"
                    android:clickable="true"
                    android:focusable="true"
                    android:contentDescription="Increase elevation" />

            </LinearLayout>

            <!-- Distance -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Estimated Distance (km)"
                android:textColor="#80FFFFFF"
                android:textSize="12sp"
                android:fontFamily="@font/poppins_medium"
                android:layout_marginTop="22dp"
                android:layout_marginBottom="6dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_dark_card"
                android:paddingHorizontal="16dp"
                android:layout_marginBottom="100dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Distance"
                    android:textColor="@android:color/white"
                    android:textSize="14sp"
                    android:fontFamily="@font/poppins_regular" />

                <TextView
                    android:id="@+id/btnDistanceDecrement"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:background="@drawable/bg_counter_btn"
                    android:text="&#8722;"
                    android:textColor="@android:color/white"
                    android:textSize="18sp"
                    android:gravity="center"
                    android:clickable="true"
                    android:focusable="true"
                    android:contentDescription="Decrease distance" />

                <TextView
                    android:id="@+id/tvDistanceValue"
                    android:layout_width="60dp"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="@android:color/white"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/poppins_bold"
                    android:gravity="center" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="km"
                    android:textColor="#80FFFFFF"
                    android:textSize="12sp"
                    android:layout_marginEnd="8dp"
                    android:fontFamily="@font/poppins_medium" />

                <TextView
                    android:id="@+id/btnDistanceIncrement"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:background="@drawable/bg_counter_btn"
                    android:text="+"
                    android:textColor="@android:color/white"
                    android:textSize="18sp"
                    android:gravity="center"
                    android:clickable="true"
                    android:focusable="true"
                    android:contentDescription="Increase distance" />

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

    </ScrollView>

    <include
    android:layout_width="wrap_content"
    android:layout_height="48dp"
    android:id="@+id/layoutFloatingCard"
    layout="@layout/dialog_floating_hike_card"
    android:layout_gravity="bottom|end"
    android:layout_marginEnd="20dp"
    android:layout_marginBottom="20dp" />

</FrameLayout>