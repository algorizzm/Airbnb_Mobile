<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- ================================= -->
        <!-- HEADER -->
        <!-- ================================= -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp">

            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_back"
                android:contentDescription="Back"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:text="Reserve"
                android:textColor="#111111"
                android:textSize="20sp"
                android:fontFamily="@font/poppins_medium"
                app:layout_constraintStart_toEndOf="@id/btnBack"
                app:layout_constraintTop_toTopOf="@id/btnBack"
                app:layout_constraintBottom_toBottomOf="@id/btnBack"
                app:layout_constraintEnd_toEndOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- ================================= -->
        <!-- LOADING -->
        <!-- ================================= -->
        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="40dp"
            android:visibility="gone"
            tools:visibility="visible" />

        <!-- ================================= -->
        <!-- CONTENT -->
        <!-- ================================= -->
        <LinearLayout
            android:id="@+id/contentContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- ================================= -->
            <!-- LISTING CARD -->
            <!-- ================================= -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/imgListing"
                    android:layout_width="120dp"
                    android:layout_height="100dp"
                    android:background="@drawable/bg_dark_card"
                    android:contentDescription="Property image"
                    android:scaleType="centerCrop"
                    android:src="@drawable/img_hike_placeholder" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="14dp"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvListingLocation"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#717171"
                        android:textSize="13sp"
                        android:fontFamily="@font/poppins_regular"
                        tools:text="Manila, Philippines" />

                    <TextView
                        android:id="@+id/tvListingTitle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:maxLines="2"
                        android:ellipsize="end"
                        android:textColor="#111111"
                        android:textSize="18sp"
                        android:fontFamily="@font/poppins_medium"
                        tools:text="Modern Apartment Near BGC" />

                    <TextView
                        android:id="@+id/tvPricePerNight"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:textColor="#111111"
                        android:textSize="15sp"
                        android:fontFamily="@font/poppins_medium"
                        tools:text="₱5,000 night" />

                </LinearLayout>

            </LinearLayout>

            <!-- DIVIDER -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="24dp"
                android:background="#EEEEEE" />

            <!-- ================================= -->
            <!-- DATES -->
            <!-- ================================= -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="Dates"
                android:textColor="#111111"
                android:textSize="20sp"
                android:fontFamily="@font/poppins_medium" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_airbnb_input"
                android:orientation="horizontal"
                android:padding="16dp">

                <!-- CHECK IN -->
                <LinearLayout
                    android:id="@+id/btnCheckIn"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:clickable="true"
                    android:focusable="true"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="CHECK-IN"
                        android:textColor="#717171"
                        android:textSize="11sp"
                        android:fontFamily="@font/poppins_medium" />

                    <TextView
                        android:id="@+id/tvCheckInDate"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Add date"
                        android:textColor="#111111"
                        android:textSize="14sp"
                        android:fontFamily="@font/poppins_regular" />

                </LinearLayout>

                <View
                    android:layout_width="1dp"
                    android:layout_height="match_parent"
                    android:layout_marginStart="12dp"
                    android:layout_marginEnd="12dp"
                    android:background="#EEEEEE" />

                <!-- CHECK OUT -->
                <LinearLayout
                    android:id="@+id/btnCheckOut"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:clickable="true"
                    android:focusable="true"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="CHECKOUT"
                        android:textColor="#717171"
                        android:textSize="11sp"
                        android:fontFamily="@font/poppins_medium" />

                    <TextView
                        android:id="@+id/tvCheckOutDate"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Add date"
                        android:textColor="#111111"
                        android:textSize="14sp"
                        android:fontFamily="@font/poppins_regular" />

                </LinearLayout>

            </LinearLayout>

            <!-- ================================= -->
            <!-- GUESTS -->
            <!-- ================================= -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:text="Guests"
                android:textColor="#111111"
                android:textSize="20sp"
                android:fontFamily="@font/poppins_medium" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Guests"
                        android:textColor="#111111"
                        android:textSize="16sp"
                        android:fontFamily="@font/poppins_medium" />

                    <TextView
                        android:id="@+id/tvMaxGuests"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:textColor="#717171"
                        android:textSize="13sp"
                        android:fontFamily="@font/poppins_regular"
                        tools:text="Maximum 4 guests" />

                </LinearLayout>

                <ImageButton
                    android:id="@+id/btnDecreaseGuests"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:background="@drawable/bg_translucent_circle"
                    android:contentDescription="Decrease guests"
                    android:src="@drawable/ic_minus"
                    app:tint="#111111" />

                <TextView
                    android:id="@+id/tvGuestCount"
                    android:layout_width="48dp"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="1"
                    android:textColor="#111111"
                    android:textSize="18sp"
                    android:fontFamily="@font/poppins_medium" />

                <ImageButton
                    android:id="@+id/btnIncreaseGuests"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:background="@drawable/bg_translucent_circle"
                    android:contentDescription="Increase guests"
                    android:src="@drawable/ic_plus"
                    app:tint="#111111" />

            </LinearLayout>

            <!-- DIVIDER -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="28dp"
                android:background="#EEEEEE" />

            <!-- ================================= -->
            <!-- PRICE DETAILS -->
            <!-- ================================= -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="Price details"
                android:textColor="#111111"
                android:textSize="20sp"
                android:fontFamily="@font/poppins_medium" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tvNightsLabel"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="₱0 x 0 nights"
                    android:textColor="#717171"
                    android:textSize="15sp"
                    android:fontFamily="@font/poppins_regular" />

                <TextView
                    android:id="@+id/tvSubtotal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="₱0"
                    android:textColor="#111111"
                    android:textSize="15sp"
                    android:fontFamily="@font/poppins_regular" />

            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="20dp"
                android:background="#EEEEEE" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Total"
                    android:textColor="#111111"
                    android:textSize="18sp"
                    android:fontFamily="@font/poppins_medium" />

                <TextView
                    android:id="@+id/tvTotalPrice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="₱0"
                    android:textColor="#111111"
                    android:textSize="18sp"
                    android:fontFamily="@font/poppins_medium" />

            </LinearLayout>

            <!-- RESERVE BUTTON -->
            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnReserve"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="32dp"
                android:layout_marginBottom="24dp"
                android:background="@drawable/bg_airbnb_primary_button"
                android:fontFamily="@font/poppins_medium"
                android:text="Confirm reservation"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="16sp" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>