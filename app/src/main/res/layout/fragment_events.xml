<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212">

    <!-- Main Content -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Top Bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingTop="44dp"
            android:paddingBottom="16dp"
            android:paddingStart="16dp"
            android:paddingEnd="16dp">

            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Events"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:fontFamily="@font/poppins_bold" />

            <ImageButton
                android:id="@+id/btnNotifications"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_marginEnd="8dp"
                android:background="@drawable/bg_translucent_circle"
                android:src="@drawable/ic_notification"
                android:contentDescription="Notifications"
                android:padding="8dp" />

            <ImageButton
                android:id="@+id/btnSettings"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="@drawable/bg_translucent_circle"
                android:src="@drawable/ic_settings"
                android:contentDescription="Settings"
                android:padding="8dp" />

        </LinearLayout>

        <!-- Navigation Tabs -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="12dp"
            android:paddingBottom="12dp">

            <!-- Explore -->
            <TextView
                android:id="@+id/tabTrack"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:background="@drawable/bg_dark_pill"
                android:gravity="center"
                android:text="Track"
                android:textColor="#80FFFFFF"
                android:textSize="13sp"
                android:fontFamily="@font/poppins_medium"
                android:clickable="true"
                android:focusable="true" />

            <!-- Events -->
            <TextView
                android:id="@+id/tabBookings"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_green_pill"
                android:gravity="center"
                android:text="Events"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:fontFamily="@font/poppins_medium"
                android:clickable="true"
                android:focusable="true" />

            <!-- History -->
            <TextView
                android:id="@+id/tabHistory"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_dark_pill"
                android:gravity="center"
                android:text="History"
                android:textColor="#80FFFFFF"
                android:textSize="13sp"
                android:fontFamily="@font/poppins_medium"
                android:clickable="true"
                android:focusable="true" />

        </LinearLayout>

        <!-- Empty State -->
        <LinearLayout
            android:id="@+id/layoutEmpty"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingStart="32dp"
            android:paddingEnd="32dp"
            android:visibility="gone">

            <ImageView
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:src="@drawable/ic_ghost"
                android:contentDescription="Empty events" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:text="No events yet"
                android:textColor="#B3FFFFFF"
                android:textSize="16sp"
                android:fontFamily="@font/poppins_medium"
                android:gravity="center" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Create your first hike event and start hosting hikers."
                android:textColor="#55FFFFFF"
                android:textSize="12sp"
                android:fontFamily="@font/poppins_regular"
                android:gravity="center" />

        </LinearLayout>

        <!-- Events List -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerEvents"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:paddingTop="8dp"
            android:paddingBottom="100dp" />

    </LinearLayout>

    <!-- FAB -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabCreateEvent"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="18dp"
        android:src="@android:drawable/ic_input_add"
        android:contentDescription="Create event"
        app:tint="@android:color/white"
        app:backgroundTint="#02D083" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>