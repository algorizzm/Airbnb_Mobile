<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#121212">

    <!-- Top Action Bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingTop="44dp"
        android:paddingBottom="12dp"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Explore"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:fontFamily="@font/poppins_bold" />

        <ImageButton
            android:id="@+id/btnNotifications"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginEnd="8dp"
            android:background="@drawable/bg_translucent_circle"
            android:src="@drawable/ic_notification"
            android:contentDescription="Notifications"
            android:padding="8dp" />

        <ImageButton
            android:id="@+id/btnSettings"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/bg_translucent_circle"
            android:src="@drawable/ic_settings"
            android:contentDescription="Settings"
            android:padding="8dp" />

    </LinearLayout>

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingTop="16dp"
        android:paddingBottom="16dp"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Explore Hikes"
            android:textColor="#FFFFFF"
            android:textSize="24sp"
            android:fontFamily="@font/poppins_bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Discover trails and adventures"
            android:textColor="#80FFFFFF"
            android:textSize="13sp"
            android:layout_marginTop="2dp"
            android:fontFamily="@font/poppins_regular" />

    </LinearLayout>

    <!-- Search + Filters -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="8dp">

        <EditText
            android:id="@+id/etSearch"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:background="@drawable/bg_edittext_border"
            android:hint="Search title or location"
            android:textColor="#FFFFFF"
            android:textColorHint="#666666"
            android:textSize="14sp"
            android:inputType="text"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:fontFamily="@font/poppins_regular" />

        <LinearLayout
            android:id="@+id/btnToggleFilters"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:layout_marginStart="8dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_edittext_border"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/ic_difficulty"
                app:tint="#02D083" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:text="Filters"
                android:textColor="#02D083"
                android:textSize="13sp"
                android:fontFamily="@font/poppins_medium" />

            <ImageView
                android:id="@+id/ivFilterChevron"
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:layout_marginStart="4dp"
                android:src="@drawable/ic_chevron_right"
                app:tint="#02D083"
                android:rotation="90" />

        </LinearLayout>

    </LinearLayout>

    <!-- Filters -->
    <LinearLayout
        android:id="@+id/layoutFilters"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_dark_card"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="8dp"
        android:padding="16dp"
        android:visibility="gone">

        <!-- Difficulty -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Difficulty"
            android:textColor="#80FFFFFF"
            android:textSize="11sp"
            android:fontFamily="@font/poppins_medium"
            android:layout_marginBottom="4dp" />

        <!-- Difficulty Chips -->
        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chipGroupDifficultyFilter"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:singleSelection="true"
            app:selectionRequired="false">

            <com.google.android.material.chip.Chip
                android:id="@+id/chipFilterAll"
                style="@style/Widget.MaterialComponents.Chip.Choice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="All"
                android:textColor="#FFFFFF"
                android:fontFamily="@font/poppins_medium"
                android:checked="true"
                app:chipBackgroundColor="@color/chip_state_color"
                app:chipStrokeColor="#02D083"
                app:chipStrokeWidth="1dp"
                app:checkedIconTint="#000000" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipFilterEasy"
                style="@style/Widget.MaterialComponents.Chip.Choice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Easy"
                android:textColor="#FFFFFF"
                android:fontFamily="@font/poppins_medium"
                app:chipBackgroundColor="@color/chip_state_color"
                app:chipStrokeColor="#02D083"
                app:chipStrokeWidth="1dp"
                app:checkedIconTint="#000000" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipFilterModerate"
                style="@style/Widget.MaterialComponents.Chip.Choice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Moderate"
                android:textColor="#FFFFFF"
                android:fontFamily="@font/poppins_medium"
                app:chipBackgroundColor="@color/chip_state_color"
                app:chipStrokeColor="#02D083"
                app:chipStrokeWidth="1dp"
                app:checkedIconTint="#000000" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipFilterHard"
                style="@style/Widget.MaterialComponents.Chip.Choice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Hard"
                android:textColor="#FFFFFF"
                android:fontFamily="@font/poppins_medium"
                app:chipBackgroundColor="@color/chip_state_color"
                app:chipStrokeColor="#02D083"
                app:chipStrokeWidth="1dp"
                app:checkedIconTint="#000000" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipFilterExpert"
                style="@style/Widget.MaterialComponents.Chip.Choice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Expert"
                android:textColor="#FFFFFF"
                android:fontFamily="@font/poppins_medium"
                app:chipBackgroundColor="@color/chip_state_color"
                app:chipStrokeColor="#02D083"
                app:chipStrokeWidth="1dp"
                app:checkedIconTint="#000000" />

        </com.google.android.material.chip.ChipGroup>

        <!-- Hidden Spinner kept for compatibility -->
        <Spinner
            android:id="@+id/spinnerDifficulty"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:visibility="gone" />

        <!-- Distance -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Distance (km)"
            android:textColor="#80FFFFFF"
            android:textSize="11sp"
            android:layout_marginTop="12dp"
            android:fontFamily="@font/poppins_medium" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:orientation="horizontal">

            <EditText
                android:id="@+id/etMinDistance"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:background="@drawable/bg_edittext_border"
                android:hint="Min"
                android:inputType="numberDecimal"
                android:textColor="#FFFFFF"
                android:textColorHint="#666666"
                android:paddingStart="12dp"
                android:paddingEnd="12dp" />

            <Space
                android:layout_width="8dp"
                android:layout_height="1dp" />

            <EditText
                android:id="@+id/etMaxDistance"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:background="@drawable/bg_edittext_border"
                android:hint="Max"
                android:inputType="numberDecimal"
                android:textColor="#FFFFFF"
                android:textColorHint="#666666"
                android:paddingStart="12dp"
                android:paddingEnd="12dp" />

        </LinearLayout>

        <!-- Max Price -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Max Price (₱)"
            android:textColor="#80FFFFFF"
            android:textSize="11sp"
            android:layout_marginTop="12dp"
            android:fontFamily="@font/poppins_medium" />

        <EditText
            android:id="@+id/etMaxPrice"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:layout_marginTop="4dp"
            android:background="@drawable/bg_edittext_border"
            android:hint="e.g. 500"
            android:inputType="numberDecimal"
            android:textColor="#FFFFFF"
            android:textColorHint="#666666"
            android:paddingStart="12dp"
            android:paddingEnd="12dp" />

        <!-- Max Duration -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Max Duration (hrs)"
            android:textColor="#80FFFFFF"
            android:textSize="11sp"
            android:layout_marginTop="12dp"
            android:fontFamily="@font/poppins_medium" />

        <EditText
            android:id="@+id/etMaxDuration"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:layout_marginTop="4dp"
            android:background="@drawable/bg_edittext_border"
            android:hint="e.g. 8"
            android:inputType="numberDecimal"
            android:textColor="#FFFFFF"
            android:textColorHint="#666666"
            android:paddingStart="12dp"
            android:paddingEnd="12dp" />

        <!-- Clear filters -->
        <TextView
            android:id="@+id/tvClearFilters"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Clear filters"
            android:textColor="#FF4444"
            android:textSize="12sp"
            android:fontFamily="@font/poppins_medium" />

    </LinearLayout>

    <!-- Empty -->
    <TextView
        android:id="@+id/tvEmpty"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="48dp"
        android:gravity="center"
        android:text="No hikes found"
        android:textColor="#80FFFFFF"
        android:textSize="15sp"
        android:fontFamily="@font/poppins_regular"
        android:visibility="gone" />

    <!-- Recycler -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerHikes"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingBottom="16dp" />

</LinearLayout>