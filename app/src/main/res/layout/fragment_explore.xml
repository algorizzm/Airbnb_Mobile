<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFFFFF">

    <!-- ============================= -->
    <!-- SEARCH BAR -->
    <!-- ============================= -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="52dp"
        android:paddingBottom="12dp"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <!-- Search Container -->
        <LinearLayout
            android:id="@+id/btnSearchContainer"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_airbnb_search"
            android:elevation="4dp"
            android:paddingStart="18dp"
            android:paddingEnd="18dp">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_search"
                app:tint="#111111"/>

            <EditText
                android:id="@+id/etSearch"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:background="@android:color/transparent"
                android:hint="Start your search"
                android:textColor="#111111"
                android:textColorHint="#444444"
                android:textSize="15sp"
                android:fontFamily="@font/poppins_medium"
                android:padding="0dp"
                android:inputType="text"/>

        </LinearLayout>

        <!-- FILTER BUTTON -->
        <!-- IMPORTANT IDS PRESERVED -->
        <LinearLayout
            android:id="@+id/btnToggleFilters"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_marginStart="10dp"
            android:gravity="center"
            android:background="@drawable/bg_filter_button"
            android:clickable="true"
            android:focusable="true"
            android:elevation="3dp">

            <ImageView
                android:id="@+id/ivFilterChevron"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_filter"
                app:tint="#111111"/>

        </LinearLayout>

    </LinearLayout>


    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#EEEEEE"/>

    <!-- ============================= -->
    <!-- FILTERS -->
    <!-- ============================= -->
    <LinearLayout
        android:id="@+id/layoutFilters"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone"
        android:layout_margin="16dp"
        android:background="@drawable/bg_airbnb_card"
        android:padding="18dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Maximum price"
            android:textColor="#111111"
            android:textSize="13sp"
            android:fontFamily="@font/poppins_medium"/>

        <EditText
            android:id="@+id/etMaxPrice"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_airbnb_input"
            android:hint="₱5000"
            android:inputType="numberDecimal"
            android:textColor="#111111"
            android:textColorHint="#999999"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Guests"
            android:textColor="#111111"
            android:textSize="13sp"
            android:layout_marginTop="16dp"
            android:fontFamily="@font/poppins_medium"/>

        <EditText
            android:id="@+id/etMinGuests"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_airbnb_input"
            android:hint="2 guests"
            android:inputType="number"
            android:textColor="#111111"
            android:textColorHint="#999999"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"/>

        <TextView
            android:id="@+id/tvClearFilters"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="Clear filters"
            android:textColor="#FF385C"
            android:textSize="13sp"
            android:fontFamily="@font/poppins_medium"/>

    </LinearLayout>

    <!-- ============================= -->
    <!-- EMPTY -->
    <!-- ============================= -->
    <TextView
        android:id="@+id/tvEmpty"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="No stays found"
        android:textColor="#999999"
        android:textSize="15sp"
        android:gravity="center"
        android:visibility="gone"
        android:layout_marginTop="40dp"/>

    <!-- ============================= -->
    <!-- MAIN CONTENT -->
    <!-- SCROLLABLE HORIZONTAL TRIPS -->
    <!-- IMPORTANT ID KEPT -->
    <!-- ============================= -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerHikes"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingBottom="90dp"
        android:paddingTop="12dp"/>

</LinearLayout>