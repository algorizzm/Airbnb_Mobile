<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_dark_card"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="Sign in Required"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:fontFamily="@font/poppins_bold" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="center"
        android:text="Create an account or log in to access this feature."
        android:textColor="#80FFFFFF"
        android:textSize="13sp"
        android:fontFamily="@font/poppins_regular" />

    <Button
        android:id="@+id/btnGuestSignUp"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginTop="20dp"
        android:background="@drawable/bg_button_green"
        android:text="Sign Up"
        android:textAllCaps="false"
        android:textColor="#000000"
        android:fontFamily="@font/poppins_bold"
        app:backgroundTint="@null" />

    <Button
        android:id="@+id/btnGuestLogIn"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginTop="8dp"
        android:background="@drawable/bg_button_outline_green"
        android:text="Log In"
        android:textAllCaps="false"
        android:textColor="#02D083"
        android:fontFamily="@font/poppins_bold"
        app:backgroundTint="@null" />

    <TextView
        android:id="@+id/btnGuestDismiss"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:gravity="center"
        android:padding="8dp"
        android:text="Maybe later"
        android:textColor="#80FFFFFF"
        android:textSize="13sp"
        android:fontFamily="@font/poppins_regular" />

</LinearLayout>
