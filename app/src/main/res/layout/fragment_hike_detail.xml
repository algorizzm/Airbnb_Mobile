<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212"
    android:orientation="vertical">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="#121212"
        app:navigationIcon="@drawable/ic_chevron_left"
        app:navigationIconTint="#02D083"
        app:title="Hike Details"
        app:titleTextColor="#FFFFFF" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Details card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_dark_card"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:id="@+id/tvTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="#FFFFFF"
                    android:textSize="22sp"
                    android:fontFamily="@font/poppins_bold" />

                <TextView
                    android:id="@+id/tvStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:textColor="#80FFFFFF"
                    android:textSize="13sp"
                    android:fontFamily="@font/poppins_regular" />

                <TextView
                    android:id="@+id/tvLocation"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"
                    android:fontFamily="@font/poppins_medium" />

                <TextView
                    android:id="@+id/tvDifficulty"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:textColor="#AAAAAA"
                    android:textSize="14sp"
                    android:fontFamily="@font/poppins_regular" />

                <TextView
                    android:id="@+id/tvDistance"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:textColor="#AAAAAA"
                    android:textSize="14sp"
                    android:fontFamily="@font/poppins_regular" />

                <TextView
                    android:id="@+id/tvPrice"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:textColor="#02D083"
                    android:textSize="14sp"
                    android:fontFamily="@font/poppins_bold" />

                <TextView
                    android:id="@+id/tvMaxParticipants"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:textColor="#AAAAAA"
                    android:textSize="14sp"
                    android:fontFamily="@font/poppins_regular" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="Description"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:fontFamily="@font/poppins_bold" />

                <TextView
                    android:id="@+id/tvDescription"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:textColor="#80FFFFFF"
                    android:textSize="14sp"
                    android:fontFamily="@font/poppins_regular" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="Guide"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:fontFamily="@font/poppins_bold" />

                <TextView
                    android:id="@+id/tvGuideName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:textColor="#80FFFFFF"
                    android:textSize="14sp"
                    android:fontFamily="@font/poppins_regular" />

                <TextView
                    android:id="@+id/tvBookingStatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:textColor="#02D083"
                    android:textSize="14sp"
                    android:fontFamily="@font/poppins_medium"
                    android:visibility="gone" />
            </LinearLayout>

            <!-- Action buttons -->
            <Button
                android:id="@+id/btnApply"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_button_green"
                android:text="Apply to Hike"
                android:textAllCaps="false"
                android:textColor="#000000"
                android:fontFamily="@font/poppins_bold"
                app:backgroundTint="@null"
                android:visibility="gone" />

            <Button
                android:id="@+id/btnCancelApplication"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_button_outline_green"
                android:text="Cancel Application"
                android:textAllCaps="false"
                android:textColor="#02D083"
                android:fontFamily="@font/poppins_bold"
                app:backgroundTint="@null"
                android:visibility="gone" />

            <Button
                android:id="@+id/btnLeaveHike"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_button_outline_green"
                android:text="Leave Hike"
                android:textAllCaps="false"
                android:textColor="#02D083"
                android:fontFamily="@font/poppins_bold"
                app:backgroundTint="@null"
                android:visibility="gone" />

            <Button
                android:id="@+id/btnEdit"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_button_green"
                android:text="Edit Hike"
                android:textAllCaps="false"
                android:textColor="#000000"
                android:fontFamily="@font/poppins_bold"
                app:backgroundTint="@null"
                android:visibility="gone" />

            <Button
                android:id="@+id/btnApplicants"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_button_outline_green"
                android:text="View Applicants"
                android:textAllCaps="false"
                android:textColor="#02D083"
                android:fontFamily="@font/poppins_bold"
                app:backgroundTint="@null"
                android:visibility="gone" />

            <Button
                android:id="@+id/btnDeleteHike"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="24dp"
                android:background="@drawable/bg_button_outline_red"
                android:text="Delete Hike"
                android:textAllCaps="false"
                android:textColor="#FF4444"
                android:fontFamily="@font/poppins_bold"
                app:backgroundTint="@null"
                android:visibility="gone" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</LinearLayout>
