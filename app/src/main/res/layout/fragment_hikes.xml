<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Top Bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingTop="44dp"
            android:paddingBottom="16dp"
            android:paddingStart="16dp"
            android:paddingEnd="16dp">

            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Dashboard"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:fontFamily="@font/poppins_bold" />

            <ImageButton
                android:id="@+id/btnNotifications"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_marginEnd="8dp"
                android:background="@drawable/bg_translucent_circle"
                android:src="@drawable/ic_notification"
                android:contentDescription="Notifications"
                android:padding="8dp" />

            <ImageButton
                android:id="@+id/btnSettings"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="@drawable/bg_translucent_circle"
                android:src="@drawable/ic_settings"
                android:contentDescription="Settings"
                android:padding="8dp" />

        </LinearLayout>

        <!-- Main Navigation Tabs -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="12dp"
            android:paddingBottom="12dp">

            <!-- Hikes -->
            <TextView
                android:id="@+id/tabHikes"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:background="@drawable/bg_green_pill"
                android:gravity="center"
                android:text="Hikes"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:fontFamily="@font/poppins_medium" />

            <!-- Bookings -->
            <TextView
                android:id="@+id/tabBookings"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_dark_pill"
                android:gravity="center"
                android:text="Bookings"
                android:textColor="#80FFFFFF"
                android:textSize="13sp"
                android:fontFamily="@font/poppins_medium" />

            <!-- History -->
            <TextView
                android:id="@+id/tabHistory"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_dark_pill"
                android:gravity="center"
                android:text="History"
                android:textColor="#80FFFFFF"
                android:textSize="13sp"
                android:fontFamily="@font/poppins_medium" />

        </LinearLayout>

        <!-- Empty State -->
        <LinearLayout
            android:id="@+id/layoutEmpty"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="72dp"
            android:orientation="vertical"
            android:gravity="center"
            android:visibility="gone">

            <ImageView
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:src="@drawable/ic_hiker"
                app:tint="#2E2E2E"
                android:contentDescription="Empty state" />

            <TextView
                android:id="@+id/tvEmpty"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="No hikes yet"
                android:textColor="#80FFFFFF"
                android:textSize="16sp"
                android:fontFamily="@font/poppins_medium" />

            <TextView
                android:id="@+id/tvEmptySub"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Your hikes, bookings, and history will appear here."
                android:textColor="#55FFFFFF"
                android:textSize="13sp"
                android:fontFamily="@font/poppins_regular" />

        </LinearLayout>

        <!-- Recycler -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerHikes"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginTop="4dp"
            android:clipToPadding="false"
            android:paddingBottom="88dp" />

    </LinearLayout>

    <!-- FAB -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabCreateHike"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="16dp"
        android:contentDescription="Create hike"
        android:src="@android:drawable/ic_input_add"
        app:tint="@android:color/white"
        app:backgroundTint="#02D083" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>