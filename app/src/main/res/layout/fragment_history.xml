<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#121212">

    <!-- Top Bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingTop="44dp"
        android:paddingBottom="16dp"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="History"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:fontFamily="@font/poppins_bold" />

        <ImageButton
            android:id="@+id/btnNotifications"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginEnd="8dp"
            android:background="@drawable/bg_translucent_circle"
            android:src="@drawable/ic_notification"
            android:contentDescription="Notifications"
            android:padding="8dp" />

        <ImageButton
            android:id="@+id/btnSettings"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/bg_translucent_circle"
            android:src="@drawable/ic_settings"
            android:contentDescription="Settings"
            android:padding="8dp" />

    </LinearLayout>

    <!-- Main Navigation Tabs -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="12dp">

        <!-- Hikes -->
        <TextView
            android:id="@+id/tabTrack"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:background="@drawable/bg_dark_pill"
            android:gravity="center"
            android:text="Track"
            android:textColor="#80FFFFFF"
            android:textSize="13sp"
            android:fontFamily="@font/poppins_medium" />

        <!-- Bookings -->
        <TextView
            android:id="@+id/tabEvents"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:background="@drawable/bg_dark_pill"
            android:gravity="center"
            android:text="Events"
            android:textColor="#80FFFFFF"
            android:textSize="13sp"
            android:fontFamily="@font/poppins_medium" />

        <!-- History -->
        <TextView
            android:id="@+id/tabHistory"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:background="@drawable/bg_green_pill"
            android:gravity="center"
            android:text="History"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:fontFamily="@font/poppins_medium" />

    </LinearLayout>

    <!-- Loading -->
    <ProgressBar
        android:id="@+id/progressLoading"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:indeterminateTint="#02D083"
        android:visibility="gone" />

    <!-- Empty state -->
    <LinearLayout
        android:id="@+id/layoutEmpty"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone">

        <ImageView
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:src="@drawable/ic_explore"
            android:tint="#2A2A2A"
            android:contentDescription="No bookings" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="No hike history yet"
            android:textColor="#80FFFFFF"
            android:textSize="15sp"
            android:fontFamily="@font/poppins_medium" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Your applied and completed hikes will appear here"
            android:textColor="#4DFFFFFF"
            android:textSize="12sp"
            android:gravity="center"
            android:paddingStart="32dp"
            android:paddingEnd="32dp"
            android:fontFamily="@font/poppins_regular" />

    </LinearLayout>

    <!-- Status text -->
    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="24dp"
        android:gravity="center"
        android:text=""
        android:textColor="#80FFFFFF"
        android:textSize="14sp"
        android:fontFamily="@font/poppins_regular"
        android:visibility="gone" />

    <!-- Booking list -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerBookings"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingTop="8dp"
        android:paddingBottom="88dp"
        android:scrollbars="none"
        android:visibility="gone" />

</LinearLayout>