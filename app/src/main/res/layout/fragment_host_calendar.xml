<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- ================================= -->
        <!-- HEADER -->
        <!-- ================================= -->

        <LinearLayout
            android:id="@+id/topHeader"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="36dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <!-- Title -->
            <TextView
                android:id="@+id/tvCalendarTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Calendar"
                android:textColor="#111111"
                android:textSize="28sp"
                android:fontFamily="@font/poppins_medium" />

            <!-- Calendar Action -->
            <ImageButton
                android:id="@+id/btnCalendarInfo"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_marginEnd="12dp"
                android:background="@drawable/bg_circle_light"
                android:contentDescription="Calendar"
                android:elevation="2dp"
                android:padding="10dp"
                android:src="@drawable/ic_calendar"
                app:tint="#222222" />

            <!-- Settings -->
            <ImageButton
                android:id="@+id/btnSettings"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@drawable/bg_circle_light"
                android:contentDescription="Settings"
                android:elevation="2dp"
                android:padding="10dp"
                android:src="@drawable/ic_settings"
                app:tint="#222222" />

        </LinearLayout>

        <!-- ================================= -->
        <!-- LISTING SELECTOR CARD -->
        <!-- ================================= -->

        <LinearLayout
            android:id="@+id/listingCard"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:layout_marginStart="24dp"
            android:layout_marginEnd="24dp"
            android:background="@drawable/bg_airbnb_card"
            android:elevation="6dp"
            android:orientation="vertical"
            android:padding="18dp"
            app:layout_constraintTop_toBottomOf="@id/topHeader"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Select Listing"
                android:textColor="#111111"
                android:textSize="15sp"
                android:fontFamily="@font/poppins_medium" />

            <Spinner
                android:id="@+id/spinnerListings"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:minHeight="48dp"
                android:background="@android:color/transparent"
                android:paddingVertical="10dp" />

        </LinearLayout>

        <!-- ================================= -->
        <!-- NO LISTINGS -->
        <!-- ================================= -->

        <TextView
            android:id="@+id/tvNoListings"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="80dp"
            android:layout_marginStart="40dp"
            android:layout_marginEnd="40dp"
            android:gravity="center"
            android:text="You don't have any listings yet"
            android:textColor="#717171"
            android:textSize="16sp"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@id/listingCard"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- ================================= -->
        <!-- MAIN CONTENT -->
        <!-- ================================= -->

        <LinearLayout
            android:id="@+id/layoutCalendarContent"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:orientation="vertical"
            android:paddingBottom="32dp"
            app:layout_constraintTop_toBottomOf="@id/listingCard"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <!-- Block Dates Button -->

            <Button
                android:id="@+id/btnBlockDates"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginStart="24dp"
                android:layout_marginEnd="24dp"
                android:layout_marginBottom="24dp"
                android:backgroundTint="#FF385C"
                android:elevation="2dp"
                android:fontFamily="@font/poppins_medium"
                android:text="Block Dates"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="16sp" />

            <!-- ================================= -->
            <!-- RESERVATIONS CARD -->
            <!-- ================================= -->

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="24dp"
                android:layout_marginEnd="24dp"
                android:layout_marginBottom="20dp"
                android:background="@drawable/bg_airbnb_card"
                android:elevation="6dp"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Reservations"
                    android:textColor="#111111"
                    android:textSize="18sp"
                    android:fontFamily="@font/poppins_medium" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Upcoming and current bookings"
                    android:textColor="#717171"
                    android:textSize="13sp" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvReservations"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:nestedScrollingEnabled="false" />

                <TextView
                    android:id="@+id/tvNoReservations"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:paddingTop="24dp"
                    android:paddingBottom="8dp"
                    android:text="No reservations yet"
                    android:textColor="#717171"
                    android:textSize="14sp"
                    android:visibility="gone" />

            </LinearLayout>

            <!-- ================================= -->
            <!-- BLOCKED DATES CARD -->
            <!-- ================================= -->

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="24dp"
                android:layout_marginEnd="24dp"
                android:background="@drawable/bg_airbnb_card"
                android:elevation="6dp"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Blocked Dates"
                    android:textColor="#111111"
                    android:textSize="18sp"
                    android:fontFamily="@font/poppins_medium" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Dates unavailable for booking"
                    android:textColor="#717171"
                    android:textSize="13sp" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvBlockedDates"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:nestedScrollingEnabled="false" />

                <TextView
                    android:id="@+id/tvNoBlockedDates"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:paddingTop="24dp"
                    android:paddingBottom="8dp"
                    android:text="No blocked dates"
                    android:textColor="#717171"
                    android:textSize="14sp"
                    android:visibility="gone" />

            </LinearLayout>

        </LinearLayout>

        <!-- ================================= -->
        <!-- LOADING -->
        <!-- ================================= -->

        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:visibility="gone"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.core.widget.NestedScrollView>