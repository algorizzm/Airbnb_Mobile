<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <!-- Header -->
    <TextView
        android:id="@+id/tvCalendarTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Calendar"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="#1A1A1A"
        android:layout_marginTop="56dp"
        android:layout_marginStart="20dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Empty state icon -->
    <ImageView
        android:id="@+id/imgCalendarIcon"
        android:layout_width="72dp"
        android:layout_height="72dp"
        android:src="@drawable/ic_calendar"
        android:alpha="0.3"
        app:tint="#717171"
        android:contentDescription="Calendar"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="32dp"/>

    <!-- Coming soon label -->
    <TextView
        android:id="@+id/tvCalendarComingSoon"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Calendar coming soon"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="#1A1A1A"
        app:layout_constraintTop_toBottomOf="@id/imgCalendarIcon"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="16dp"/>

    <TextView
        android:id="@+id/tvCalendarSubtitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="View your reservation dates and availability in one place. This feature is coming in a future update."
        android:textSize="14sp"
        android:textColor="#717171"
        android:gravity="center"
        android:lineSpacingExtra="4dp"
        android:layout_marginTop="8dp"
        android:layout_marginHorizontal="40dp"
        app:layout_constraintTop_toBottomOf="@id/tvCalendarComingSoon"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>
