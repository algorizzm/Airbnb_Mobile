<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingTop="60dp"
        android:paddingBottom="40dp">

        <ImageButton
            android:id="@+id/btnClose"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_gravity="start"
            android:layout_marginBottom="6dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_chevron_left"
            android:drawableTint="#80FFFFFF"
            android:padding="8dp"
            android:contentDescription="Close" />

        <!-- Logo -->
        <ImageView
            android:id="@+id/logo"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:layout_gravity="center_horizontal"
            android:src="@drawable/verdant_logo"
            android:contentDescription="Logo" />

        <!-- Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="16dp"
            android:text="Welcome back"
            android:textColor="#FFFFFF"
            android:textSize="26sp"
            android:fontFamily="@font/poppins_bold" />

        <!-- Subtitle -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="36dp"
            android:text="Sign in to continue your journey"
            android:textColor="#80FFFFFF"
            android:textSize="14sp"
            android:fontFamily="@font/poppins_regular" />

        <!-- Email label -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Email"
            android:textColor="#CCFFFFFF"
            android:textSize="13sp"
            android:fontFamily="@font/poppins_medium"
            android:layout_marginBottom="6dp" />

        <!-- Email field -->
        <EditText
            android:id="@+id/etEmail"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@drawable/bg_edittext_border"
            android:hint="Enter your email"
            android:textColor="#FFFFFF"
            android:textColorHint="#60FFFFFF"
            android:inputType="textEmailAddress"
            android:gravity="center_vertical"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:drawableStart="@drawable/ic_email_vector"
            android:drawablePadding="10dp"
            android:drawableTint="#80FFFFFF"
            android:fontFamily="@font/poppins_regular" />

        <!-- Password label -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Password"
            android:textColor="#CCFFFFFF"
            android:textSize="13sp"
            android:fontFamily="@font/poppins_medium"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="6dp" />

        <!-- Password field -->
        <EditText
            android:id="@+id/etPassword"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@drawable/bg_edittext_border"
            android:hint="Enter your password"
            android:textColor="#FFFFFF"
            android:textColorHint="#60FFFFFF"
            android:inputType="textPassword"
            android:gravity="center_vertical"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:drawableStart="@drawable/ic_lock_vector"
            android:drawablePadding="10dp"
            android:drawableTint="#80FFFFFF"
            android:fontFamily="@font/poppins_regular" />

        <!-- Error -->
        <TextView
            android:id="@+id/tvError"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textColor="#FF4C4C"
            android:textSize="12sp"
            android:fontFamily="@font/poppins_regular"
            android:drawableStart="@drawable/ic_error_vector"
            android:drawablePadding="8dp"
            android:gravity="center_vertical"
            android:visibility="gone" />

        <!-- Sign In button -->
        <Button
            android:id="@+id/btnContinue"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="28dp"
            android:background="@drawable/bg_button_green"
            android:text="Sign In"
            android:textAllCaps="false"
            android:textColor="#000000"
            android:textSize="15sp"
            android:fontFamily="@font/poppins_bold"
            app:backgroundTint="@null" />

        <!-- Divider -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="20dp">

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1"
                android:background="#2A2A2A" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="  or continue with  "
                android:textColor="#666666"
                android:textSize="12sp"
                android:fontFamily="@font/poppins_regular" />

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1"
                android:background="#2A2A2A" />

        </LinearLayout>

        <!-- Google button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnGoogle"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Continue with Google"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:fontFamily="@font/poppins_medium"
            android:backgroundTint="#1E1E1E"
            app:icon="@drawable/ic_google"
            app:iconPadding="12dp"
            app:iconGravity="textStart"
            app:iconTint="@null"
            app:strokeColor="#2A2A2A"
            app:strokeWidth="1dp"
            app:cornerRadius="28dp" />

        <!-- Apple button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnApple"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="10dp"
            android:text="Continue with Apple"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:fontFamily="@font/poppins_medium"
            android:backgroundTint="#1E1E1E"
            app:icon="@drawable/ic_apple_vector"
            app:iconPadding="12dp"
            app:iconGravity="textStart"
            app:iconTint="#FFFFFF"
            app:strokeColor="#2A2A2A"
            app:strokeWidth="1dp"
            app:cornerRadius="28dp" />

        <!-- Footer -->
        <TextView
            android:id="@+id/tvFooter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="32dp"
            android:text="Don't have an account? Sign up"
            android:textColor="#80FFFFFF"
            android:textSize="13sp"
            android:fontFamily="@font/poppins_regular" />

    </LinearLayout>

</ScrollView>