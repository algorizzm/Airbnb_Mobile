<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212">

    <!-- Main Screen -->
    <LinearLayout
        android:id="@+id/layoutMessagesRoot"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingTop="44dp"
            android:paddingBottom="12dp"
            android:paddingStart="16dp"
            android:paddingEnd="16dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Messages"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:fontFamily="@font/poppins_bold" />

            <ImageButton
                android:id="@+id/btnNotifications"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_marginEnd="8dp"
                android:background="@drawable/bg_translucent_circle"
                android:src="@drawable/ic_notification"
                android:contentDescription="Notifications"
                android:padding="8dp" />

            <ImageButton
                android:id="@+id/btnSettings"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="@drawable/bg_translucent_circle"
                android:src="@drawable/ic_settings"
                android:contentDescription="Settings"
                android:padding="8dp" />

        </LinearLayout>

        <!-- Authenticated Content -->
        <LinearLayout
            android:id="@+id/layoutAuthenticatedContent"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="No messages yet"
                android:textColor="#80FFFFFF"
                android:textSize="15sp"
                android:fontFamily="@font/poppins_regular" />

        </LinearLayout>

        <!-- Guest Locked State -->
        <LinearLayout
            android:id="@+id/layoutGuestState"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:paddingStart="32dp"
            android:paddingEnd="32dp"
            android:visibility="gone">

            <ImageView
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:src="@drawable/ic_hiker"
                android:tint="#02D083"
                android:layout_marginBottom="18dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Messages Locked"
                android:textColor="#FFFFFF"
                android:textSize="22sp"
                android:fontFamily="@font/poppins_bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:gravity="center"
                android:text="Log in to access your messages and conversations."
                android:textColor="#80FFFFFF"
                android:textSize="14sp"
                android:fontFamily="@font/poppins_regular" />

        </LinearLayout>

    </LinearLayout>

    <!-- Dim Background -->
    <View
        android:id="@+id/viewGuestOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#88000000"
        android:visibility="gone" />

    <!-- Popup Prompt -->
    <include
        android:id="@+id/layoutGuestPrompt"
        layout="@layout/dialog_guest_prompt"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:layout_margin="20dp"
        android:visibility="gone" />

</FrameLayout>