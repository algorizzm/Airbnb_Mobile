<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <!-- ================================= -->
    <!-- HEADER ACTIONS -->
    <!-- ================================= -->

    <LinearLayout
        android:id="@+id/topActions"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="36dp"
        android:gravity="end"
        android:orientation="horizontal"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Search -->
        <ImageButton
            android:id="@+id/btnSearch"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginEnd="12dp"
            android:background="@drawable/bg_circle_light"
            android:contentDescription="Search"
            android:padding="10dp"
            android:src="@drawable/ic_search"
            app:tint="#222222" />

        <!-- Settings -->
        <ImageButton
            android:id="@+id/btnSettings"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/bg_circle_light"
            android:contentDescription="Settings"
            android:padding="10dp"
            android:src="@drawable/ic_settings"
            app:tint="#222222" />

    </LinearLayout>

    <!-- ================================= -->
    <!-- TITLE -->
    <!-- ================================= -->

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginTop="12dp"
        android:text="Messages"
        android:textColor="#111111"
        android:textSize="30sp"
        android:fontFamily="@font/poppins_medium"
        app:layout_constraintTop_toBottomOf="@id/topActions"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- ================================= -->
    <!-- FILTER CHIPS -->
    <!-- ================================= -->

    <HorizontalScrollView
        android:id="@+id/filterContainer"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:scrollbars="none"
        app:layout_constraintTop_toBottomOf="@id/tvTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="24dp"
            android:paddingEnd="24dp">

            <!-- ALL -->
            <TextView
                android:id="@+id/chipAll"
                android:layout_width="wrap_content"
                android:layout_height="34dp"
                android:background="@drawable/bg_chip_selected"
                android:fontFamily="@font/poppins_medium"
                android:gravity="center"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:text="All"
                android:textColor="#FFFFFF"
                android:textSize="13sp" />

            <!-- HOSTING -->
            <TextView
                android:id="@+id/chipHosting"
                android:layout_width="wrap_content"
                android:layout_height="34dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_chip_unselected"
                android:fontFamily="@font/poppins_regular"
                android:gravity="center"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:text="Hosting"
                android:textColor="#222222"
                android:textSize="13sp" />

            <!-- TRAVELLING -->
            <TextView
                android:id="@+id/chipTravelling"
                android:layout_width="wrap_content"
                android:layout_height="34dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_chip_unselected"
                android:fontFamily="@font/poppins_regular"
                android:gravity="center"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:text="Travelling"
                android:textColor="#222222"
                android:textSize="13sp" />

            <!-- SUPPORT -->
            <TextView
                android:id="@+id/chipSupport"
                android:layout_width="wrap_content"
                android:layout_height="34dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_chip_unselected"
                android:fontFamily="@font/poppins_regular"
                android:gravity="center"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:text="Support"
                android:textColor="#222222"
                android:textSize="13sp" />

        </LinearLayout>

    </HorizontalScrollView>

    <!-- ================================= -->
    <!-- DIVIDER -->
    <!-- ================================= -->

    <View
        android:id="@+id/headerDivider"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:layout_marginTop="18dp"
        android:background="#F1F1F1"
        app:layout_constraintTop_toBottomOf="@id/filterContainer"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ================================= -->
    <!-- AUTHENTICATED EMPTY STATE -->
    <!-- ================================= -->

    <LinearLayout
        android:id="@+id/layoutAuthenticatedContent"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="visible"
        app:layout_constraintTop_toBottomOf="@id/headerDivider"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Icon Circle -->
        <FrameLayout
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:background="@drawable/bg_empty_icon_circle">

            <ImageView
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_message"
                app:tint="#222222" />

        </FrameLayout>

        <!-- Title -->
        <TextView
            android:id="@+id/tvEmptyTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:text="No messages yet"
            android:textColor="#111111"
            android:textSize="20sp"
            android:fontFamily="@font/poppins_medium" />

        <!-- Subtitle -->
        <TextView
            android:id="@+id/tvEmptySubtitle"
            android:layout_width="260dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:gravity="center"
            android:text="When you receive a new message, it will appear here."
            android:textAlignment="center"
            android:textColor="#8B8B8B"
            android:textSize="15sp"
            android:fontFamily="@font/poppins_regular" />

    </LinearLayout>

    <!-- ================================= -->
    <!-- GUEST STATE -->
    <!-- ================================= -->

    <LinearLayout
        android:id="@+id/layoutGuestState"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingTop="36dp"
        android:paddingEnd="24dp"
        android:background="#FFFFFF"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/headerDivider"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Guest Title -->
        <TextView
            android:id="@+id/tvGuestTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Log in to view messages"
            android:textColor="#111111"
            android:textSize="24sp"
            android:lineSpacingExtra="2dp"
            android:fontFamily="@font/poppins_medium" />

        <!-- Guest Subtitle -->
        <TextView
            android:id="@+id/tvGuestSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="Connect with hosts, ask questions, and manage your trips."
            android:textColor="#6A6A6A"
            android:textSize="16sp"
            android:lineSpacingExtra="2dp"
            android:fontFamily="@font/poppins_regular" />

        <!-- Login Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnLogin"
            android:layout_width="114dp"
            android:layout_height="52dp"
            android:layout_marginTop="28dp"
            android:text="Log in"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:fontFamily="@font/poppins_medium"
            android:backgroundTint="#FF385C"
            app:cornerRadius="12dp" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>