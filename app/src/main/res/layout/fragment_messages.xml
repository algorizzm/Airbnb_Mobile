<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- TOP ACTIONS -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="end"
            android:orientation="horizontal"
            android:paddingStart="24dp"
            android:paddingTop="44dp"
            android:paddingEnd="24dp">

            <!-- Search -->
            <ImageButton
                android:id="@+id/btnSearch"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_marginEnd="12dp"
                android:background="@drawable/bg_circle_light"
                android:padding="10dp"
                android:src="@drawable/ic_search"
                android:contentDescription="Search"
                app:tint="#222222" />

            <!-- Settings -->
            <ImageButton
                android:id="@+id/btnSettings"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@drawable/bg_circle_light"
                android:padding="10dp"
                android:src="@drawable/ic_settings"
                android:contentDescription="Settings"
                app:tint="#222222" />

        </LinearLayout>

        <!-- TITLE -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginTop="10dp"
            android:text="Messages"
            android:textColor="#111111"
            android:textSize="28sp"
            android:fontFamily="@font/poppins_medium" />

        <!-- FILTER CHIPS -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="24dp"
            android:paddingEnd="24dp">

            <!-- ALL -->
            <TextView
                android:id="@+id/chipAll"
                android:layout_width="wrap_content"
                android:layout_height="34dp"
                android:background="@drawable/bg_chip_selected"
                android:fontFamily="@font/poppins_medium"
                android:gravity="center"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:text="All"
                android:textColor="#FFFFFF"
                android:textSize="13sp" />

            <!-- HOSTING -->
            <TextView
                android:id="@+id/chipHosting"
                android:layout_width="wrap_content"
                android:layout_height="34dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_chip_unselected"
                android:fontFamily="@font/poppins_regular"
                android:gravity="center"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:text="Hosting"
                android:textColor="#222222"
                android:textSize="13sp" />

            <!-- TRAVELLING -->
            <TextView
                android:id="@+id/chipTravelling"
                android:layout_width="wrap_content"
                android:layout_height="34dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_chip_unselected"
                android:fontFamily="@font/poppins_regular"
                android:gravity="center"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:text="Travelling"
                android:textColor="#222222"
                android:textSize="13sp" />

            <!-- SUPPORT -->
            <TextView
                android:id="@+id/chipSupport"
                android:layout_width="wrap_content"
                android:layout_height="34dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_chip_unselected"
                android:fontFamily="@font/poppins_regular"
                android:gravity="center"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:text="Support"
                android:textColor="#222222"
                android:textSize="13sp" />

        </LinearLayout>

        <!-- MAIN CONTENT -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <!-- AUTHENTICATED EMPTY STATE -->
            <LinearLayout
                android:id="@+id/layoutAuthenticatedContent"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="24dp">

                <!-- Icon Bubble -->
                <FrameLayout
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    android:background="@drawable/bg_empty_icon_circle"
                    android:foreground="?attr/selectableItemBackgroundBorderless">

                    <ImageView
                        android:layout_width="30dp"
                        android:layout_height="30dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_message"
                        app:tint="#222222" />

                </FrameLayout>

                <!-- Title -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:fontFamily="@font/poppins_medium"
                    android:text="You don’t have any messages"
                    android:textColor="#111111"
                    android:textSize="21sp" />

                <!-- Subtitle -->
                <TextView
                    android:layout_width="270dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:fontFamily="@font/poppins_regular"
                    android:gravity="center"
                    android:lineSpacingExtra="2dp"
                    android:text="When you receive a new message, it will appear here."
                    android:textColor="#8B8B8B"
                    android:textSize="15sp" />

            </LinearLayout>

            <!-- GUEST STATE -->
            <LinearLayout
                android:id="@+id/layoutGuestState"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="32dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/poppins_medium"
                    android:text="Log in to view messages"
                    android:textColor="#111111"
                    android:textSize="22sp" />

                <TextView
                    android:layout_width="280dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:fontFamily="@font/poppins_regular"
                    android:gravity="center"
                    android:text="Connect with hosts, ask questions, and manage your trips."
                    android:textColor="#8B8B8B"
                    android:textSize="15sp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnLogin"
                    android:layout_width="wrap_content"
                    android:layout_height="48dp"
                    android:layout_marginTop="28dp"
                    android:fontFamily="@font/poppins_medium"
                    android:paddingStart="28dp"
                    android:paddingEnd="28dp"
                    android:text="Log in"
                    android:textAllCaps="false"
                    android:textColor="@android:color/white"
                    android:textSize="15sp"
                    app:backgroundTint="#FF385C"
                    app:cornerRadius="24dp" />

            </LinearLayout>

        </FrameLayout>

    </LinearLayout>

</FrameLayout>