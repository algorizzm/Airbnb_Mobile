<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#121212">

    <!-- Top bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingTop="44dp"
        android:paddingBottom="12dp"
        android:paddingStart="4dp"
        android:paddingEnd="16dp">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@null"
            android:src="@drawable/ic_chevron_left"
            android:tint="#FFFFFF"
            android:contentDescription="Back"
            android:padding="12dp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Notifications"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:fontFamily="@font/poppins_bold" />

        <!-- Mark all read -->
        <TextView
            android:id="@+id/btnMarkAllRead"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Mark all read"
            android:textColor="#02D083"
            android:textSize="12sp"
            android:fontFamily="@font/poppins_medium"
            android:padding="8dp"
            android:visibility="gone" />

    </LinearLayout>

    <!-- Section label -->
    <TextView
        android:id="@+id/tvSectionLabel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="6dp"
        android:text="RECENT"
        android:textColor="#80FFFFFF"
        android:textSize="11sp"
        android:letterSpacing="0.12"
        android:fontFamily="@font/poppins_medium"
        android:visibility="gone" />

    <!-- Empty state -->
    <LinearLayout
        android:id="@+id/layoutEmpty"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="visible">

        <ImageView
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:src="@drawable/ic_notification_bell"
            android:tint="#2A2A2A"
            android:contentDescription="No notifications" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="No notifications yet"
            android:textColor="#80FFFFFF"
            android:textSize="15sp"
            android:fontFamily="@font/poppins_medium" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Booking updates and hike alerts will appear here"
            android:textColor="#4DFFFFFF"
            android:textSize="12sp"
            android:gravity="center"
            android:paddingStart="32dp"
            android:paddingEnd="32dp"
            android:fontFamily="@font/poppins_regular" />

    </LinearLayout>

    <!-- Notification list -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerNotifications"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingBottom="88dp"
        android:scrollbars="none"
        android:visibility="gone" />

</LinearLayout>
