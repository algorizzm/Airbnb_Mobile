<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212">

    <!-- TOP BAR -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:background="#121212">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_chevron_left"
            android:padding="6dp"
            android:contentDescription="Back" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Payment Method"
            android:textColor="@android:color/white"
            android:textSize="17sp"
            android:textStyle="bold"
            android:fontFamily="@font/poppins_bold"
            android:gravity="center" />

        <View android:layout_width="36dp" android:layout_height="36dp" />

    </LinearLayout>

    <!-- SCROLLABLE BODY -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="56dp"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="12dp">

            <!-- Booking Summary card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_dark_card"
                android:padding="14dp"
                android:layout_marginBottom="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Booking Summary"
                    android:textColor="@android:color/white"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/poppins_bold"
                    android:layout_marginBottom="12dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <ImageView
                        android:id="@+id/imgHikeThumbnail"
                        android:layout_width="64dp"
                        android:layout_height="64dp"
                        android:scaleType="centerCrop"
                        android:src="@drawable/sample_hike"
                        android:background="@drawable/bg_dark_card"
                        android:contentDescription="Hike thumbnail" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="14dp">

                        <TextView
                            android:id="@+id/tvHikeName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Mt. Pulag Hike"
                            android:textColor="@android:color/white"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:fontFamily="@font/poppins_bold" />

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginTop="4dp">

                            <TextView
                                android:id="@+id/tvBookingDate"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="September 19, 2021"
                                android:textColor="#B3FFFFFF"
                                android:textSize="12sp"
                                android:fontFamily="@font/poppins_regular" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="  ·  "
                                android:textColor="#80FFFFFF"
                                android:textSize="12sp" />

                            <TextView
                                android:id="@+id/tvBookingTime"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="5:00 AM"
                                android:textColor="#B3FFFFFF"
                                android:textSize="12sp"
                                android:fontFamily="@font/poppins_regular" />

                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginTop="4dp">

                            <TextView
                                android:id="@+id/tvParticipants"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="1 Participant"
                                android:textColor="#B3FFFFFF"
                                android:textSize="12sp"
                                android:fontFamily="@font/poppins_regular" />

                            <TextView
                                android:id="@+id/tvBookingPrice"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="&#8369; 2,200.00"
                                android:textColor="@android:color/white"
                                android:textSize="13sp"
                                android:textStyle="bold"
                                android:fontFamily="@font/poppins_bold" />

                        </LinearLayout>

                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>

            <!-- Select Payment Method label -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Select Payment Method"
                android:textColor="@android:color/white"
                android:textSize="15sp"
                android:textStyle="bold"
                android:fontFamily="@font/poppins_bold"
                android:layout_marginBottom="14dp" />

            <!-- Cash Payment group -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Cash Payment"
                android:textColor="#02D083"
                android:textSize="12sp"
                android:fontFamily="@font/poppins_bold"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:id="@+id/rowCash"
                android:layout_width="match_parent"
                android:layout_height="72dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_payment_method_row"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:layout_marginBottom="16dp"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/ic_payment_cash"
                    android:layout_marginEnd="14dp"
                    android:contentDescription="Cash payment" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Pay on arrival (Cash)"
                        android:textColor="@android:color/white"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:fontFamily="@font/poppins_bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Pay in cash at the jump-off point"
                        android:textColor="#80FFFFFF"
                        android:textSize="11sp"
                        android:fontFamily="@font/poppins_regular"
                        android:layout_marginTop="2dp" />

                </LinearLayout>

                <RadioButton
                    android:id="@+id/radioCash"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:button="@null"
                    android:background="@drawable/bg_radio_unselected"
                    android:checked="false" />

            </LinearLayout>

            <!-- Online Payment group -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Online Payment"
                android:textColor="#02D083"
                android:textSize="12sp"
                android:fontFamily="@font/poppins_bold"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <!-- GCash -->
            <LinearLayout
                android:id="@+id/rowGcash"
                android:layout_width="match_parent"
                android:layout_height="72dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_payment_method_row"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:layout_marginBottom="8dp"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/ic_payment_gcash"
                    android:layout_marginEnd="14dp"
                    android:contentDescription="GCash" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="GCash"
                        android:textColor="@android:color/white"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:fontFamily="@font/poppins_bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Pay securely using GCash"
                        android:textColor="#80FFFFFF"
                        android:textSize="11sp"
                        android:fontFamily="@font/poppins_regular"
                        android:layout_marginTop="2dp" />

                </LinearLayout>

                <RadioButton
                    android:id="@+id/radioGcash"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:button="@null"
                    android:background="@drawable/bg_radio_unselected"
                    android:checked="false" />

            </LinearLayout>

            <!-- PayMaya -->
            <LinearLayout
                android:id="@+id/rowPaymaya"
                android:layout_width="match_parent"
                android:layout_height="72dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_payment_method_row"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:layout_marginBottom="8dp"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/ic_payment_paymaya"
                    android:layout_marginEnd="14dp"
                    android:contentDescription="PayMaya" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="PayMaya"
                        android:textColor="@android:color/white"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:fontFamily="@font/poppins_bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Pay securely using PayMaya"
                        android:textColor="#80FFFFFF"
                        android:textSize="11sp"
                        android:fontFamily="@font/poppins_regular"
                        android:layout_marginTop="2dp" />

                </LinearLayout>

                <RadioButton
                    android:id="@+id/radioPaymaya"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:button="@null"
                    android:background="@drawable/bg_radio_unselected"
                    android:checked="false" />

            </LinearLayout>

            <!-- Credit / Debit Card -->
            <LinearLayout
                android:id="@+id/rowCard"
                android:layout_width="match_parent"
                android:layout_height="72dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_payment_method_row"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:layout_marginBottom="8dp"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/ic_payment_card"
                    android:layout_marginEnd="14dp"
                    android:contentDescription="Credit or Debit Card" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Credit / Debit Card"
                        android:textColor="@android:color/white"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:fontFamily="@font/poppins_bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Visa, Mastercard, JCB"
                        android:textColor="#80FFFFFF"
                        android:textSize="11sp"
                        android:fontFamily="@font/poppins_regular"
                        android:layout_marginTop="2dp" />

                </LinearLayout>

                <RadioButton
                    android:id="@+id/radioCard"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:button="@null"
                    android:background="@drawable/bg_radio_unselected"
                    android:checked="false" />

            </LinearLayout>

            <!-- Bank Transfer -->
            <LinearLayout
                android:id="@+id/rowBank"
                android:layout_width="match_parent"
                android:layout_height="72dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_payment_method_row"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:layout_marginBottom="20dp"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/ic_payment_bank"
                    android:layout_marginEnd="14dp"
                    android:contentDescription="Bank Transfer" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Bank Transfer"
                        android:textColor="@android:color/white"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:fontFamily="@font/poppins_bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Pay via BPI, BDO, Metrobank, etc."
                        android:textColor="#80FFFFFF"
                        android:textSize="11sp"
                        android:fontFamily="@font/poppins_regular"
                        android:layout_marginTop="2dp" />

                </LinearLayout>

                <RadioButton
                    android:id="@+id/radioBank"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:button="@null"
                    android:background="@drawable/bg_radio_unselected"
                    android:checked="false" />

            </LinearLayout>

            <!-- Amount to Pay row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_dark_card"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Amount to Pay"
                    android:textColor="@android:color/white"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/poppins_bold" />

                <TextView
                    android:id="@+id/tvAmountToPay"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="&#8369; 2,200.00"
                    android:textColor="#02D083"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/poppins_bold" />

            </LinearLayout>

            <!-- Confirm Booking button -->
            <Button
                android:id="@+id/btnConfirmBooking"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="24dp"
                android:background="@drawable/bg_button_green"
                android:text="Confirm Booking"
                android:textAllCaps="false"
                android:textColor="@android:color/black"
                android:textSize="16sp"
                android:textStyle="bold"
                android:fontFamily="@font/poppins_bold"
                app:backgroundTint="@null" />

        </LinearLayout>

    </ScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
