<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212"
    android:clipToPadding="false"
    android:paddingBottom="90dp">


    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- GUEST STATE -->
        <LinearLayout
            android:id="@+id/layoutGuest"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:padding="24dp"
            android:paddingTop="80dp"
            android:visibility="gone">

            <ImageView
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:src="@drawable/bg_circle"
                android:contentDescription="Guest avatar" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="Browsing as Guest"
                android:textColor="@android:color/white"
                android:textSize="20sp"
                android:fontFamily="@font/poppins_bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:gravity="center"
                android:text="Create an account to access all features."
                android:textColor="#80FFFFFF"
                android:textSize="14sp"
                android:fontFamily="@font/poppins_regular" />

            <Button
                android:id="@+id/btnLogin"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="28dp"
                android:background="@drawable/bg_button_green"
                android:text="Login"
                android:textAllCaps="false"
                android:textColor="@android:color/black"
                android:fontFamily="@font/poppins_bold"
                app:backgroundTint="@null" />

            <Button
                android:id="@+id/btnSignup"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_button_outline_green"
                android:text="Sign Up"
                android:textAllCaps="false"
                android:textColor="#02D083"
                android:fontFamily="@font/poppins_bold"
                app:backgroundTint="@null" />

        </LinearLayout>

        <!-- AUTHENTICATED PROFILE -->
        <LinearLayout
            android:id="@+id/layoutProfile"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="visible">

            <!-- Banner + Avatar wrapper — RelativeLayout lets avatar overlap the banner edge -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <!-- Banner (220dp tall) -->
                <FrameLayout
                    android:id="@+id/bannerFrame"
                    android:layout_width="match_parent"
                    android:layout_height="220dp"
                    android:layout_alignParentTop="true">

                    <!-- Banner image -->
                    <ImageView
                        android:id="@+id/imgBanner"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:src="@drawable/img_hike_placeholder"
                        android:contentDescription="Profile banner" />

                    <!-- Gradient overlay -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_profile_banner_overlay" />

                    <!-- Top action buttons row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_gravity="top"
                        android:paddingTop="44dp"
                        android:paddingLeft="16dp"
                        android:paddingRight="16dp">

                        <View
                            android:layout_width="0dp"
                            android:layout_height="1dp"
                            android:layout_weight="1" />

                        <ImageButton
                            android:id="@+id/btnNotifications"
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:layout_marginEnd="8dp"
                            android:background="@drawable/bg_circle"
                            android:src="@drawable/ic_notification"
                            android:contentDescription="Notifications"
                            android:padding="8dp" />

                        <ImageButton
                            android:id="@+id/btnSettings"
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:background="@drawable/bg_circle"
                            android:src="@drawable/ic_settings"
                            android:contentDescription="Settings"
                            android:padding="8dp" />

                    </LinearLayout>

                </FrameLayout>

                <!-- Avatar + upload — positioned to straddle the banner bottom edge -->
                <FrameLayout
                    android:layout_width="88dp"
                    android:layout_height="88dp"
                    android:layout_below="@id/bannerFrame"
                    android:layout_centerHorizontal="true"
                    android:layout_marginTop="-44dp"
                    android:elevation="8dp">

                    <ImageView
                        android:id="@+id/imgAvatar"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_avatar_border"
                        android:scaleType="centerCrop"
                        android:src="@drawable/bg_circle"
                        android:contentDescription="Profile photo"
                        android:padding="3dp" />

                    <ImageButton
                        android:id="@+id/btnUploadPhoto"
                        android:layout_width="26dp"
                        android:layout_height="26dp"
                        android:layout_gravity="bottom|end"
                        android:background="@drawable/bg_button_green"
                        android:src="@drawable/ic_upload"
                        android:contentDescription="Upload photo"
                        android:padding="5dp"
                        app:backgroundTint="@null" />

                </FrameLayout>

            </RelativeLayout>

            <!-- Name + username + location — padded to clear the overlapping avatar -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center_horizontal"
                android:paddingTop="56dp"
                android:paddingLeft="16dp"
                android:paddingRight="16dp">

                <TextView
                    android:id="@+id/tvFullName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Juan dela Cruz"
                    android:textColor="@android:color/white"
                    android:textSize="20sp"
                    android:fontFamily="@font/poppins_bold" />

                <TextView
                    android:id="@+id/tvUsername"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@juandelacruz"
                    android:textColor="#80FFFFFF"
                    android:textSize="13sp"
                    android:fontFamily="@font/poppins_regular" />

                <!-- Location row -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="6dp">

                    <ImageView
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:src="@drawable/ic_trail"
                        android:tint="#80FFFFFF"
                        android:contentDescription="Location" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="4dp"
                        android:text="Philippines"
                        android:textColor="#80FFFFFF"
                        android:textSize="12sp"
                        android:fontFamily="@font/poppins_regular" />

                </LinearLayout>

            </LinearLayout>

            <!-- Stats row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingLeft="12dp"
                android:paddingRight="12dp"
                android:paddingTop="16dp"
                android:paddingBottom="4dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/bg_stat_card"
                    android:paddingTop="10dp"
                    android:paddingBottom="10dp"
                    android:paddingLeft="4dp"
                    android:paddingRight="4dp"
                    android:layout_marginEnd="5dp">

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@drawable/ic_hikes"
                        android:tint="#02D083"
                        android:contentDescription="Hikes icon"
                        android:layout_marginBottom="4dp" />

                    <TextView
                        android:id="@+id/tvStatHikes"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="12"
                        android:textColor="#02D083"
                        android:textSize="18sp"
                        android:fontFamily="@font/poppins_bold"
                        android:maxLines="1" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Hikes"
                        android:textColor="#80FFFFFF"
                        android:textSize="10sp"
                        android:fontFamily="@font/poppins_regular" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/bg_stat_card"
                    android:paddingTop="10dp"
                    android:paddingBottom="10dp"
                    android:paddingLeft="4dp"
                    android:paddingRight="4dp"
                    android:layout_marginEnd="5dp">

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@drawable/ic_distance"
                        android:tint="#02D083"
                        android:contentDescription="Distance icon"
                        android:layout_marginBottom="4dp" />

                    <TextView
                        android:id="@+id/tvStatDistance"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="86.4km"
                        android:textColor="#02D083"
                        android:textSize="15sp"
                        android:fontFamily="@font/poppins_bold"
                        android:maxLines="1" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Distance"
                        android:textColor="#80FFFFFF"
                        android:textSize="10sp"
                        android:fontFamily="@font/poppins_regular" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/bg_stat_card"
                    android:paddingTop="10dp"
                    android:paddingBottom="10dp"
                    android:paddingLeft="4dp"
                    android:paddingRight="4dp">

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@drawable/ic_check_circle"
                        android:tint="#02D083"
                        android:contentDescription="Summits icon"
                        android:layout_marginBottom="4dp" />

                    <TextView
                        android:id="@+id/tvStatSummits"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="4"
                        android:textColor="#02D083"
                        android:textSize="18sp"
                        android:fontFamily="@font/poppins_bold"
                        android:maxLines="1" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Summits"
                        android:textColor="#80FFFFFF"
                        android:textSize="10sp"
                        android:fontFamily="@font/poppins_regular" />

                </LinearLayout>

            </LinearLayout>

            <!-- About card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_dark_card"
                android:layout_marginLeft="16dp"
                android:layout_marginRight="16dp"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="16dp"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="About"
                        android:textColor="@android:color/white"
                        android:textSize="15sp"
                        android:fontFamily="@font/poppins_bold" />

                    <TextView
                        android:id="@+id/btnEditBio"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_button_outline_green"
                        android:text="EDIT BIO"
                        android:textColor="#02D083"
                        android:textSize="11sp"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:paddingTop="6dp"
                        android:paddingBottom="6dp"
                        android:fontFamily="@font/poppins_medium" />

                </LinearLayout>

                <TextView
                    android:id="@+id/tvBio"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Passionate hiker and nature lover. Always chasing the next summit and the best sunrise views."
                    android:textColor="#CCFFFFFF"
                    android:textSize="13sp"
                    android:lineSpacingMultiplier="1.4"
                    android:fontFamily="@font/poppins_regular" />

            </LinearLayout>

            <!-- Recent Hikes -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingLeft="16dp"
                android:paddingRight="16dp"
                android:paddingBottom="8dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingBottom="12dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Recent Hikes"
                        android:textColor="@android:color/white"
                        android:textSize="15sp"
                        android:fontFamily="@font/poppins_bold" />

                    <TextView
                        android:id="@+id/tvSeeAllHikes"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="View All"
                        android:textColor="#02D083"
                        android:textSize="13sp"
                        android:fontFamily="@font/poppins_medium" />

                </LinearLayout>

                <!-- Hike thumbnails row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <FrameLayout
                        android:layout_width="0dp"
                        android:layout_height="130dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="6dp">

                        <ImageView
                            android:id="@+id/imgRecentHike1"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleType="centerCrop"
                            android:src="@drawable/img_hike_placeholder"
                            android:contentDescription="Recent hike 1" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_gravity="bottom"
                            android:background="#CC000000"
                            android:orientation="vertical"
                            android:padding="6dp">

                            <TextView
                                android:id="@+id/tvRecentHike1"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Mt. Pulag"
                                android:textColor="#FFFFFF"
                                android:textSize="11sp"
                                android:fontFamily="@font/poppins_bold" />

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Jan 12 · 8.2km"
                                android:textColor="#80FFFFFF"
                                android:textSize="10sp"
                                android:fontFamily="@font/poppins_regular" />

                        </LinearLayout>

                    </FrameLayout>

                    <FrameLayout
                        android:layout_width="0dp"
                        android:layout_height="130dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="6dp">

                        <ImageView
                            android:id="@+id/imgRecentHike2"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleType="centerCrop"
                            android:src="@drawable/img_hike_placeholder"
                            android:contentDescription="Recent hike 2" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_gravity="bottom"
                            android:background="#CC000000"
                            android:orientation="vertical"
                            android:padding="6dp">

                            <TextView
                                android:id="@+id/tvRecentHike2"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Mt. Apo"
                                android:textColor="#FFFFFF"
                                android:textSize="11sp"
                                android:fontFamily="@font/poppins_bold" />

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Feb 3 · 12.5km"
                                android:textColor="#80FFFFFF"
                                android:textSize="10sp"
                                android:fontFamily="@font/poppins_regular" />

                        </LinearLayout>

                    </FrameLayout>

                    <FrameLayout
                        android:layout_width="0dp"
                        android:layout_height="130dp"
                        android:layout_weight="1">

                        <ImageView
                            android:id="@+id/imgRecentHike3"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleType="centerCrop"
                            android:src="@drawable/img_hike_placeholder"
                            android:contentDescription="Recent hike 3" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_gravity="bottom"
                            android:background="#CC000000"
                            android:orientation="vertical"
                            android:padding="6dp">

                            <TextView
                                android:id="@+id/tvRecentHike3"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Mt. Kanlaon"
                                android:textColor="#FFFFFF"
                                android:textSize="11sp"
                                android:fontFamily="@font/poppins_bold" />

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Mar 20 · 9.8km"
                                android:textColor="#80FFFFFF"
                                android:textSize="10sp"
                                android:fontFamily="@font/poppins_regular" />

                        </LinearLayout>

                    </FrameLayout>

                </LinearLayout>

            </LinearLayout>

            <!-- Achievements section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingLeft="16dp"
                android:paddingRight="16dp"
                android:paddingBottom="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Achievements"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"
                    android:fontFamily="@font/poppins_bold"
                    android:paddingBottom="12dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center">

                    <!-- Badge 1 -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">

                        <ImageView
                            android:layout_width="50dp"
                            android:layout_height="50dp"
                            android:background="@drawable/bg_achievement_badge"
                            android:src="@drawable/ic_badge_first_hike"
                            android:padding="10dp"
                            android:contentDescription="First Hike badge" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="First Hike"
                            android:textColor="#80FFFFFF"
                            android:textSize="10sp"
                            android:gravity="center"
                            android:fontFamily="@font/poppins_regular" />

                    </LinearLayout>

                    <!-- Badge 2 -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">

                        <ImageView
                            android:layout_width="50dp"
                            android:layout_height="50dp"
                            android:background="@drawable/bg_achievement_badge"
                            android:src="@drawable/ic_badge_explorer"
                            android:padding="10dp"
                            android:contentDescription="Explorer badge" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="Explorer"
                            android:textColor="#80FFFFFF"
                            android:textSize="10sp"
                            android:gravity="center"
                            android:fontFamily="@font/poppins_regular" />

                    </LinearLayout>

                    <!-- Badge 3 -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">

                        <ImageView
                            android:layout_width="50dp"
                            android:layout_height="50dp"
                            android:background="@drawable/bg_achievement_badge"
                            android:src="@drawable/ic_badge_distance"
                            android:padding="10dp"
                            android:contentDescription="Distance badge" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="50km Club"
                            android:textColor="#80FFFFFF"
                            android:textSize="10sp"
                            android:gravity="center"
                            android:fontFamily="@font/poppins_regular" />

                    </LinearLayout>

                    <!-- Badge 4 -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">

                        <ImageView
                            android:layout_width="50dp"
                            android:layout_height="50dp"
                            android:background="@drawable/bg_achievement_badge"
                            android:src="@drawable/ic_badge_night"
                            android:padding="10dp"
                            android:contentDescription="Night Hiker badge" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="Night Hiker"
                            android:textColor="#80FFFFFF"
                            android:textSize="10sp"
                            android:gravity="center"
                            android:fontFamily="@font/poppins_regular" />

                    </LinearLayout>

                    <!-- Badge 5 -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">

                        <ImageView
                            android:layout_width="50dp"
                            android:layout_height="50dp"
                            android:background="@drawable/bg_achievement_badge"
                            android:src="@drawable/ic_badge_sunrise"
                            android:padding="10dp"
                            android:contentDescription="Sunrise badge" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="Sunrise"
                            android:textColor="#80FFFFFF"
                            android:textSize="10sp"
                            android:gravity="center"
                            android:fontFamily="@font/poppins_regular" />

                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>


            <!-- Settings rows -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_dark_card"
                android:layout_marginLeft="16dp"
                android:layout_marginRight="16dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="16dp">

                <!-- Account Information -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/bg_settings_row_dark"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp">

                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:src="@drawable/ic_account_info"
                        android:tint="#02D083"
                        android:contentDescription="Account Information" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="12dp"
                        android:text="Account Information"
                        android:textColor="#FFFFFF"
                        android:textSize="14sp"
                        android:fontFamily="@font/poppins_medium" />

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@drawable/ic_chevron_right"
                        android:tint="#80FFFFFF"
                        android:contentDescription="Navigate" />

                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#2A2A2A"
                    android:layout_marginStart="50dp" />

                <!-- Notifications -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/bg_settings_row_dark"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp">

                    <ImageView
