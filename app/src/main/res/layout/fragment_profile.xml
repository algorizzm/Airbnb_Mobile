<?xml version="1.0" encoding="utf-8"?>

<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <!-- ========================================================= -->
    <!-- MAIN SCROLL -->
    <!-- ========================================================= -->

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="80dp">

            <!-- ========================================================= -->
            <!-- GUEST -->
            <!-- ========================================================= -->

            <LinearLayout
                android:id="@+id/layoutGuest"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center_horizontal"
                android:paddingStart="28dp"
                android:paddingEnd="28dp"
                android:paddingTop="120dp"
                android:visibility="gone">

                <ImageView
                    android:id="@+id/imgGuestAvatar"
                    android:layout_width="90dp"
                    android:layout_height="90dp"
                    android:src="@drawable/blank_profile"
                    android:scaleType="centerCrop"
                    android:background="@drawable/bg_airbnb_avatar"
                    android:padding="2dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Welcome to Airbnb"
                    android:textColor="#111111"
                    android:textSize="26sp"
                    android:layout_marginTop="24dp"
                    android:fontFamily="@font/poppins_medium"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Log in or sign up to start booking unique stays and experiences."
                    android:textColor="#717171"
                    android:textSize="14sp"
                    android:gravity="center"
                    android:layout_marginTop="10dp"
                    android:fontFamily="@font/poppins_regular"/>

                <Button
                    android:id="@+id/btnLogin"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="32dp"
                    android:background="@drawable/bg_airbnb_primary_button"
                    android:text="Log in"
                    android:textAllCaps="false"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"
                    app:backgroundTint="@null"/>

                <Button
                    android:id="@+id/btnSignup"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/bg_airbnb_outline_button"
                    android:text="Sign up"
                    android:textAllCaps="false"
                    android:textColor="#111111"
                    android:textSize="15sp"
                    app:backgroundTint="@null"/>

            </LinearLayout>

            <!-- ========================================================= -->
            <!-- PROFILE -->
            <!-- ========================================================= -->

            <LinearLayout
                android:id="@+id/layoutProfile"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- HEADER -->

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingTop="44dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="end"
                        android:paddingStart="24dp"
                        android:paddingEnd="24dp">

                        <ImageButton
                            android:id="@+id/btnNotifications"
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            android:background="@drawable/bg_circle_light"
                            android:padding="10dp"
                            android:src="@drawable/ic_notification"
                            app:tint="#222222"/>

                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvProfileTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="24dp"
                        android:layout_marginTop="12dp"
                        android:text="Profile"
                        android:textColor="#111111"
                        android:textSize="30sp"
                        android:fontFamily="@font/poppins_medium"/>

                </LinearLayout>

                <!-- PROFILE CARD -->

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="24dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center_horizontal"
                        android:background="@drawable/bg_airbnb_card"
                        android:padding="28dp">

                        <FrameLayout
                            android:layout_width="110dp"
                            android:layout_height="110dp">

                            <ImageView
                                android:id="@+id/imgAvatar"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:background="@drawable/bg_airbnb_avatar"
                                android:scaleType="centerCrop"/>

                            <TextView
                                android:id="@+id/tvAvatarInitial"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:gravity="center"
                                android:text="J"
                                android:textColor="#121212"
                                android:textSize="36sp"
                                android:fontFamily="@font/poppins_bold"/>

                            <ImageButton
                                android:id="@+id/btnUploadPhoto"
                                android:layout_width="34dp"
                                android:layout_height="34dp"
                                android:layout_gravity="bottom|end"
                                android:background="@drawable/bg_airbnb_upload"
                                android:src="@drawable/ic_upload"
                                android:padding="7dp"/>

                            <ProgressBar
                                android:id="@+id/progressAvatar"
                                android:layout_width="26dp"
                                android:layout_height="26dp"
                                android:layout_gravity="center"
                                android:visibility="gone"/>

                        </FrameLayout>

                        <TextView
                            android:id="@+id/tvFullName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Julian Miguel"
                            android:textColor="#111111"
                            android:textSize="24sp"
                            android:layout_marginTop="18dp"
                            android:fontFamily="@font/poppins_bold"/>

                        <TextView
                            android:id="@+id/tvUsername"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="\@julianmiguel"
                            android:textColor="#717171"
                            android:textSize="14sp"/>

                        <TextView
                            android:id="@+id/tvLocation"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Philippines"
                            android:textColor="#717171"
                            android:textSize="14sp"
                            android:layout_marginTop="4dp"/>

                        <Button
                            android:id="@+id/rowEditProfile"
                            android:layout_width="wrap_content"
                            android:layout_height="48dp"
                            android:layout_marginTop="18dp"
                            android:background="@drawable/bg_airbnb_outline_button"
                            android:text="Edit profile"
                            android:textAllCaps="false"
                            android:textColor="#111111"
                            app:backgroundTint="@null"/>

                    </LinearLayout>

                </LinearLayout>

                <!-- ABOUT -->

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="24dp"
                    android:layout_marginEnd="24dp"
                    android:background="@drawable/bg_airbnb_card"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="About"
                        android:textColor="#111111"
                        android:textSize="18sp"
                        android:fontFamily="@font/poppins_medium"/>

                    <TextView
                        android:id="@+id/tvBio"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Tell guests about yourself."
                        android:textColor="#444444"
                        android:textSize="14sp"
                        android:layout_marginTop="10dp"/>

                    <TextView
                        android:id="@+id/btnEditBio"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Edit"
                        android:textColor="#FF385C"
                        android:textSize="14sp"
                        android:layout_marginTop="12dp"/>

                </LinearLayout>

                <!-- HOST CARD (NOT STICKY) -->

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="24dp"
                    android:layout_marginEnd="24dp"
                    android:layout_marginTop="20dp"
                    android:background="@drawable/bg_airbnb_card"
                    android:elevation="8dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="18dp">

                    <ImageView
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        android:src="@drawable/ic_airbnb"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="14dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Become a host"
                            android:textColor="#111111"
                            android:textSize="18sp"
                            android:fontFamily="@font/poppins_medium"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="It’s easy to start hosting and earn extra income."
                            android:textColor="#717171"
                            android:textSize="13sp"
                            android:layout_marginTop="4dp"/>

                    </LinearLayout>

                </LinearLayout>

                <!-- SETTINGS -->

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_margin="24dp"
                    android:background="@drawable/bg_airbnb_card">

                    <LinearLayout
                        android:id="@+id/tvSeeAllHikes"
                        android:layout_width="match_parent"
                        android:layout_height="64dp"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="20dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Your trips"
                            android:textSize="15sp"
                            android:textColor="#111111"/>

                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/rowHostingAccess"
                        android:layout_width="match_parent"
                        android:layout_height="64dp"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="20dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Become a host"
                            android:textSize="15sp"
                            android:textColor="#111111"/>

                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/rowAppInfo"
                        android:layout_width="match_parent"
                        android:layout_height="64dp"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="20dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="App info"
                            android:textSize="15sp"
                            android:textColor="#111111"/>

                    </LinearLayout>

                </LinearLayout>

                <!-- LOGOUT -->

                <LinearLayout
                    android:id="@+id/rowLogout"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:layout_marginStart="24dp"
                    android:layout_marginEnd="24dp"
                    android:layout_marginBottom="40dp"
                    android:background="@drawable/bg_airbnb_card"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Log out"
                        android:textColor="#FF385C"
                        android:textSize="15sp"/>

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

    </ScrollView>

    <!-- ========================================================= -->
    <!-- STICKY SWITCH MODE CARD -->
    <!-- ========================================================= -->

    <LinearLayout
        android:id="@+id/floatingHostingCard"
        android:saveEnabled="false"
        android:layout_width="220dp"
        android:layout_height="52dp"
        android:layout_gravity="bottom|center_horizontal"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingStart="18dp"
        android:paddingEnd="18dp"
        android:background="@drawable/bg_airbnb_dark_button"
        android:elevation="10dp"
        android:clickable="true"
        android:focusable="true">

        <ImageView
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:src="@drawable/ic_switch" />

        <TextView
            android:id="@+id/tvFloatingHostingTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="2dp"
            android:text="Switch to hosting"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:fontFamily="@font/poppins_medium"
            android:maxLines="1" />

    </LinearLayout>

</FrameLayout>