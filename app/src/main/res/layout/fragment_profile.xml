<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212"
    android:clipToPadding="false"
    android:paddingBottom="90dp">


    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- GUEST STATE -->
        <LinearLayout
            android:id="@+id/layoutGuest"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:padding="24dp"
            android:layout_marginTop="160dp"
            android:paddingTop="80dp"
            android:visibility="gone">

            <FrameLayout
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:layout_marginBottom="16dp">

                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/imgGuestAvatar"
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    android:layout_marginBottom="16dp"
                    android:scaleType="centerCrop"
                    android:src="@drawable/blank_profile"
                    android:contentDescription="Guest avatar"
                    app:strokeWidth="1dp"
                    app:strokeColor="#02D083"
                    app:shapeAppearanceOverlay="@style/AirbnbCircleImageView" />

            </FrameLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="Browsing as Guest"
                android:textColor="@android:color/white"
                android:textSize="20sp"
                android:fontFamily="@font/poppins_bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:gravity="center"
                android:text="Create an account to access all features."
                android:textColor="#80FFFFFF"
                android:textSize="14sp"
                android:fontFamily="@font/poppins_regular" />

            <Button
                android:id="@+id/btnLogin"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="28dp"
                android:background="@drawable/bg_button_green"
                android:text="Login"
                android:textAllCaps="false"
                android:textColor="@android:color/black"
                android:fontFamily="@font/poppins_bold"
                app:backgroundTint="@null" />

            <Button
                android:id="@+id/btnSignup"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_button_outline_green"
                android:text="Sign Up"
                android:textAllCaps="false"
                android:textColor="#02D083"
                android:fontFamily="@font/poppins_bold"
                app:backgroundTint="@null" />

        </LinearLayout>

        <!-- AUTHENTICATED PROFILE -->
        <LinearLayout
            android:id="@+id/layoutProfile"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="visible">

            <!-- Banner + Avatar wrapper -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <!-- Banner (220dp tall) — clickable for upload -->
                <FrameLayout
                    android:id="@+id/bannerFrame"
                    android:layout_width="match_parent"
                    android:layout_height="220dp"
                    android:layout_alignParentTop="true"
                    android:clickable="true"
                    android:focusable="true">

                    <!-- Banner image -->
                    <ImageView
                        android:id="@+id/imgBanner"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:src="@drawable/img_hike_placeholder"
                        android:contentDescription="Profile banner" />

                    <!-- Gradient overlay -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_profile_banner_overlay" />

                    <!-- Banner upload progress -->
                    <ProgressBar
                        android:id="@+id/progressBanner"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:layout_gravity="center"
                        android:indeterminateTint="#02D083"
                        android:visibility="gone" />

                    <!-- Top action buttons row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_gravity="top"
                        android:paddingTop="44dp"
                        android:paddingLeft="16dp"
                        android:paddingRight="16dp">

                        <View
                            android:layout_width="0dp"
                            android:layout_height="1dp"
                            android:layout_weight="1" />

                        <!-- Notification button with badge -->
                        <FrameLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="8dp">

                            <ImageButton
                                android:id="@+id/btnNotifications"
                                android:layout_width="36dp"
                                android:layout_height="36dp"
                                android:src="@drawable/ic_notification"
                                android:background="@drawable/bg_translucent_circle"
                                android:contentDescription="Notifications"
                                android:padding="8dp" />

                            <TextView
                                android:id="@+id/tvNotifBadge"
                                android:layout_width="16dp"
                                android:layout_height="16dp"
                                android:layout_gravity="top|end"
                                android:background="@drawable/bg_circle"
                                android:backgroundTint="#FF4444"
                                android:gravity="center"
                                android:textColor="#FFFFFF"
                                android:textSize="9sp"
                                android:fontFamily="@font/poppins_bold"
                                android:visibility="gone" />

                        </FrameLayout>

                        <ImageButton
                            android:id="@+id/btnSettings"
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:src="@drawable/ic_settings"
                            android:background="@drawable/bg_translucent_circle"
                            android:contentDescription="Settings"
                            android:padding="8dp" />

                    </LinearLayout>

                </FrameLayout>

                <!-- Avatar — clickable for upload -->
                <FrameLayout
                    android:layout_width="88dp"
                    android:layout_height="88dp"
                    android:layout_below="@id/bannerFrame"
                    android:layout_centerHorizontal="true"
                    android:layout_marginTop="-44dp"
                    android:elevation="8dp"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:id="@+id/imgAvatar"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_avatar_border"
                        android:scaleType="centerCrop"
                        android:src="@drawable/bg_circle"
                        android:contentDescription="Profile photo"
                        android:padding="3dp" />

                    <!-- Initials shown when no profile photo is set -->
                    <TextView
                        android:id="@+id/tvAvatarInitial"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:textColor="#FFFFFF"
                        android:textSize="28sp"
                        android:fontFamily="@font/poppins_bold"
                        android:visibility="gone" />

                    <!-- Avatar upload progress -->
                    <ProgressBar
                        android:id="@+id/progressAvatar"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_gravity="center"
                        android:indeterminateTint="#02D083"
                        android:visibility="gone" />

                    <ImageButton
                        android:id="@+id/btnUploadPhoto"
                        android:layout_width="26dp"
                        android:layout_height="26dp"
                        android:layout_gravity="bottom|end"
                        android:background="@drawable/bg_button_green"
                        android:src="@drawable/ic_upload"
                        android:contentDescription="Upload photo"
                        android:padding="5dp"
                        app:backgroundTint="@null" />

                </FrameLayout>

            </RelativeLayout>

            <!-- Name + username + location — padded to clear the overlapping avatar -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center_horizontal"
                android:paddingTop="56dp"
                android:paddingLeft="16dp"
                android:paddingRight="16dp">

                <TextView
                    android:id="@+id/tvFullName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Juan dela Cruz"
                    android:textColor="@android:color/white"
                    android:textSize="20sp"
                    android:fontFamily="@font/poppins_bold" />

                <TextView
                    android:id="@+id/tvUsername"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@juandelacruz"
                    android:textColor="#80FFFFFF"
                    android:textSize="13sp"
                    android:fontFamily="@font/poppins_regular" />

                <!-- Location row -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="6dp">

                    <ImageView
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:src="@drawable/ic_location"
                        app:tint="#80FFFFFF"
                        android:contentDescription="Location" />

                    <TextView
                        android:id="@+id/tvLocation"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="4dp"
                        android:text="Philippines"
                        android:textColor="#80FFFFFF"
                        android:textSize="12sp"
                        android:fontFamily="@font/poppins_regular" />
                </LinearLayout>

            </LinearLayout>

            <!-- Stats row - REMOVED for Airbnb MVP -->
            <!-- Hiking statistics (Hikes, Distance, Summits) removed -->
            <!-- Future: Could add Trips, Reviews, Years Hosting stats -->

            <!-- About card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_dark_card"
                android:layout_marginLeft="16dp"
                android:layout_marginRight="16dp"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="16dp"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="About"
                        android:textColor="@android:color/white"
                        android:textSize="15sp"
                        android:fontFamily="@font/poppins_bold" />

                    <TextView
                        android:id="@+id/btnEditBio"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_button_outline_green"
                        android:text="EDIT BIO"
                        android:textColor="#02D083"
                        android:textSize="11sp"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:paddingTop="6dp"
                        android:paddingBottom="6dp"
                        android:fontFamily="@font/poppins_medium" />

                </LinearLayout>

                <TextView
                    android:id="@+id/tvBio"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Passionate hiker and nature lover. Always chasing the next summit and the best sunrise views."
                    android:textColor="#CCFFFFFF"
                    android:textSize="13sp"
                    android:lineSpacingMultiplier="1.4"
                    android:fontFamily="@font/poppins_regular" />

            </LinearLayout>

            <!-- Hosting Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_dark_card"
                android:layout_marginLeft="16dp"
                android:layout_marginRight="16dp"
                android:layout_marginBottom="16dp"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Hosting"
                    android:textColor="@android:color/white"
                    android:textSize="15sp"
                    android:fontFamily="@font/poppins_bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="List your space and start earning"
                    android:textColor="#CCFFFFFF"
                    android:textSize="13sp"
                    android:fontFamily="@font/poppins_regular" />

                <Button
                    android:id="@+id/btnSwitchToHosting"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/bg_button_green"
                    android:text="Manage Listings"
                    android:textAllCaps="false"
                    android:textColor="@android:color/black"
                    android:fontFamily="@font/poppins_bold"
                    app:backgroundTint="@null" />

            </LinearLayout>

            <!-- Recent Trips -->
            <LinearLayout
                android:id="@+id/layoutRecentHikes"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingLeft="16dp"
                android:paddingRight="16dp"
                android:paddingBottom="8dp"
                android:visibility="visible">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingBottom="12dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Recent Trips"
                        android:textColor="@android:color/white"
                        android:textSize="15sp"
                        android:fontFamily="@font/poppins_bold" />

                    <TextView
                        android:id="@+id/tvSeeAllHikes"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="View All"
                        android:textColor="#02D083"
                        android:textSize="13sp"
                        android:fontFamily="@font/poppins_medium" />

                </LinearLayout>

                <!-- Hike thumbnails row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <FrameLayout
                        android:id="@+id/cardRecentHike1"
                        android:layout_width="0dp"
                        android:layout_height="130dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="6dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground">

                        <ImageView
                            android:id="@+id/imgRecentHike1"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleType="centerCrop"
                            android:src="@drawable/img_hike_placeholder"
                            android:contentDescription="Recent hike 1" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_gravity="bottom"
                            android:background="#CC000000"
                            android:orientation="vertical"
                            android:padding="6dp">

                            <TextView
                                android:id="@+id/tvRecentHike1"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Mt. Pulag"
                                android:textColor="#FFFFFF"
                                android:textSize="11sp"
                                android:fontFamily="@font/poppins_bold" />

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Jan 12 · 8.2km"
                                android:textColor="#80FFFFFF"
                                android:textSize="10sp"
                                android:fontFamily="@font/poppins_regular" />

                        </LinearLayout>

                    </FrameLayout>

                    <FrameLayout
                        android:id="@+id/cardRecentHike2"
                        android:layout_width="0dp"
                        android:layout_height="130dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="6dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground">

                        <ImageView
                            android:id="@+id/imgRecentHike2"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleType="centerCrop"
                            android:src="@drawable/img_hike_placeholder"
                            android:contentDescription="Recent hike 2" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_gravity="bottom"
                            android:background="#CC000000"
                            android:orientation="vertical"
                            android:padding="6dp">

                            <TextView
                                android:id="@+id/tvRecentHike2"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Mt. Apo"
                                android:textColor="#FFFFFF"
                                android:textSize="11sp"
                                android:fontFamily="@font/poppins_bold" />

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Feb 3 · 12.5km"
                                android:textColor="#80FFFFFF"
                                android:textSize="10sp"
                                android:fontFamily="@font/poppins_regular" />

                        </LinearLayout>

                    </FrameLayout>

                    <FrameLayout
                        android:id="@+id/cardRecentHike3"
                        android:layout_width="0dp"
                        android:layout_height="130dp"
                        android:layout_weight="1"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground">

                        <ImageView
                            android:id="@+id/imgRecentHike3"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleType="centerCrop"
                            android:src="@drawable/img_hike_placeholder"
                            android:contentDescription="Recent hike 3" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_gravity="bottom"
                            android:background="#CC000000"
                            android:orientation="vertical"
                            android:padding="6dp">

                            <TextView
                                android:id="@+id/tvRecentHike3"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Mt. Kanlaon"
                                android:textColor="#FFFFFF"
                                android:textSize="11sp"
                                android:fontFamily="@font/poppins_bold" />

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Mar 20 · 9.8km"
                                android:textColor="#80FFFFFF"
                                android:textSize="10sp"
                                android:fontFamily="@font/poppins_regular" />

                        </LinearLayout>

                    </FrameLayout>

                </LinearLayout>

            </LinearLayout>

            <!-- Achievements section - REMOVED for Airbnb MVP -->
            <!-- Hiking badges (First Hike, Explorer, 50km Club, etc.) removed -->
            <!-- Future: Could add Airbnb-relevant badges (Superhost, Reviews, etc.) -->

        </LinearLayout>

    </LinearLayout>

</ScrollView>