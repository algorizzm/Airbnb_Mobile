<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:fillViewport="true"
    android:background="@drawable/bg_auth_sheet">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingTop="12dp"
        android:paddingBottom="32dp"
        android:animateLayoutChanges="true">

        <!-- Drag Handle -->
        <View
            android:layout_width="40dp"
            android:layout_height="4dp"
            android:layout_gravity="center"
            android:layout_marginBottom="16dp"
            android:background="@drawable/bg_drag_handle" />

        <!-- Back Button -->
        <ImageButton
            android:id="@+id/btnClose"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_chevron_left"
            android:padding="2dp"
            app:tint="#222222"
            android:contentDescription="Back" />

        <!-- Logo -->
        <ImageView
            android:id="@+id/logo"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_gravity="center"
            android:layout_marginTop="20dp"
            android:src="@drawable/ic_airbnb"
            android:contentDescription="Logo" />

        <!-- Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="24dp"
            android:text="Create account"
            android:textColor="#111111"
            android:textSize="28sp"
            android:fontFamily="@font/poppins_bold" />

        <!-- Subtitle -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="8dp"
            android:text="Start hosting and traveling today"
            android:textColor="#777777"
            android:textSize="14sp"
            android:fontFamily="@font/poppins_regular" />

        <!-- Username -->
        <EditText
            android:id="@+id/etName"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="32dp"
            android:background="@drawable/bg_input_outline"
            android:hint="Username"
            android:paddingHorizontal="16dp"
            android:textColor="#111111"
            android:textColorHint="#888888"
            android:textSize="15sp"
            android:fontFamily="@font/poppins_regular"
            android:inputType="textPersonName" />

        <!-- Email -->
        <EditText
            android:id="@+id/etEmail"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_input_outline"
            android:hint="Email"
            android:paddingHorizontal="16dp"
            android:textColor="#111111"
            android:textColorHint="#888888"
            android:textSize="15sp"
            android:fontFamily="@font/poppins_regular"
            android:inputType="textEmailAddress"
            android:importantForAutofill="yes" />

        <!-- Password -->
        <EditText
            android:id="@+id/etPassword"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_input_outline"
            android:hint="Password"
            android:paddingHorizontal="16dp"
            android:textColor="#111111"
            android:textColorHint="#888888"
            android:textSize="15sp"
            android:fontFamily="@font/poppins_regular"
            android:inputType="textPassword"
            android:importantForAutofill="yes" />

        <!-- Confirm Password -->
        <EditText
            android:id="@+id/etConfirmPassword"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_input_outline"
            android:hint="Confirm Password"
            android:paddingHorizontal="16dp"
            android:textColor="#111111"
            android:textColorHint="#888888"
            android:textSize="15sp"
            android:fontFamily="@font/poppins_regular"
            android:inputType="textPassword" />

        <!-- Error -->
        <TextView
            android:id="@+id/tvError"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:textColor="#FF385C"
            android:textSize="13sp"
            android:fontFamily="@font/poppins_regular"
            android:visibility="gone" />

        <!-- Create Account Button -->
        <Button
            android:id="@+id/btnHiker"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="24dp"
            android:background="@drawable/bg_button_airbnb"
            android:text="Create account"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:fontFamily="@font/poppins_bold"
            app:backgroundTint="@null" />

        <!-- Footer -->
        <TextView
            android:id="@+id/tvFooter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="20dp"
            android:text="Already have an account? Sign in"
            android:textColor="#FF385C"
            android:textSize="15sp"
            android:fontFamily="@font/poppins_medium"
            android:padding="8dp"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground" />

    </LinearLayout>

</ScrollView>