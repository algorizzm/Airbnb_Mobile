<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingTop="60dp"
        android:paddingBottom="40dp">

        <!-- Logo -->
        <ImageView
            android:id="@+id/logo"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:layout_gravity="center_horizontal"
            android:src="@drawable/ic_logo"
            android:contentDescription="Logo" />

        <!-- Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="16dp"
            android:text="Create account"
            android:textColor="#FFFFFF"
            android:textSize="26sp"
            android:fontFamily="@font/poppins_bold" />

        <!-- Subtitle -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="36dp"
            android:text="Start your hiking journey today"
            android:textColor="#80FFFFFF"
            android:textSize="14sp"
            android:fontFamily="@font/poppins_regular" />

        <!-- Username label -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Username"
            android:textColor="#CCFFFFFF"
            android:textSize="13sp"
            android:fontFamily="@font/poppins_medium"
            android:layout_marginBottom="6dp" />

        <!-- Username field -->
        <EditText
            android:id="@+id/etName"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@drawable/bg_edittext_border"
            android:hint="Enter username"
            android:textColor="#FFFFFF"
            android:textColorHint="#60FFFFFF"
            android:gravity="center_vertical"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:drawableStart="@drawable/ic_user_vector"
            android:drawablePadding="10dp"
            android:drawableTint="#80FFFFFF"
            android:fontFamily="@font/poppins_regular" />

        <!-- Email label -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Email"
            android:textColor="#CCFFFFFF"
            android:textSize="13sp"
            android:fontFamily="@font/poppins_medium"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="6dp" />

        <!-- Email field -->
        <EditText
            android:id="@+id/etEmail"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@drawable/bg_edittext_border"
            android:hint="Enter your email"
            android:textColor="#FFFFFF"
            android:textColorHint="#60FFFFFF"
            android:inputType="textEmailAddress"
            android:gravity="center_vertical"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:drawableStart="@drawable/ic_email_vector"
            android:drawablePadding="10dp"
            android:drawableTint="#80FFFFFF"
            android:fontFamily="@font/poppins_regular" />

        <!-- Password label -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Password"
            android:textColor="#CCFFFFFF"
            android:textSize="13sp"
            android:fontFamily="@font/poppins_medium"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="6dp" />

        <!-- Password field -->
        <EditText
            android:id="@+id/etPassword"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@drawable/bg_edittext_border"
            android:hint="Enter password"
            android:textColor="#FFFFFF"
            android:textColorHint="#60FFFFFF"
            android:inputType="textPassword"
            android:gravity="center_vertical"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:drawableStart="@drawable/ic_lock_vector"
            android:drawablePadding="10dp"
            android:drawableTint="#80FFFFFF"
            android:fontFamily="@font/poppins_regular" />

        <!-- Confirm Password label -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Confirm Password"
            android:textColor="#CCFFFFFF"
            android:textSize="13sp"
            android:fontFamily="@font/poppins_medium"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="6dp" />

        <!-- Confirm Password field -->
        <EditText
            android:id="@+id/etConfirmPassword"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@drawable/bg_edittext_border"
            android:hint="Confirm password"
            android:textColor="#FFFFFF"
            android:textColorHint="#60FFFFFF"
            android:inputType="textPassword"
            android:gravity="center_vertical"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:drawableStart="@drawable/ic_lock_vector"
            android:drawablePadding="10dp"
            android:drawableTint="#80FFFFFF"
            android:fontFamily="@font/poppins_regular" />

        <!-- Error -->
        <TextView
            android:id="@+id/tvError"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textColor="#FF4C4C"
            android:textSize="12sp"
            android:fontFamily="@font/poppins_regular"
            android:visibility="gone" />

        <!-- Sign Up button -->
        <Button
            android:id="@+id/btnHiker"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="28dp"
            android:background="@drawable/bg_button_green"
            android:text="Sign Up"
            android:textAllCaps="false"
            android:textColor="#000000"
            android:textSize="15sp"
            android:fontFamily="@font/poppins_bold"
            app:backgroundTint="@null" />

        <!-- Divider -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="20dp">

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1"
                android:background="#2A2A2A" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="  or  "
                android:textColor="#666666"
                android:textSize="12sp"
                android:fontFamily="@font/poppins_regular" />

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1"
                android:background="#2A2A2A" />

        </LinearLayout>

        <!-- Become a Guide button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnGuide"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Become a Guide"
            android:textAllCaps="false"
            android:textColor="#02D083"
            android:textSize="14sp"
            android:fontFamily="@font/poppins_medium"
            android:backgroundTint="#1E1E1E"
            app:strokeColor="#02D083"
            app:strokeWidth="1dp"
            app:cornerRadius="28dp" />

        <!-- Footer -->
        <TextView
            android:id="@+id/tvFooter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="32dp"
            android:text="Already have an account? Sign in"
            android:textColor="#80FFFFFF"
            android:textSize="13sp"
            android:fontFamily="@font/poppins_regular" />

    </LinearLayout>

</ScrollView>
