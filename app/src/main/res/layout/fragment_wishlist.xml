<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <!-- ================================= -->
    <!-- HEADER -->
    <!-- ================================= -->

    <LinearLayout
        android:id="@+id/headerContainer"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="36dp"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Title -->
        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Wishlists"
            android:textColor="#111111"
            android:textSize="30sp"
            android:fontFamily="@font/poppins_medium"/>

    </LinearLayout>

    <!-- ================================= -->
    <!-- DIVIDER -->
    <!-- ================================= -->

    <View
        android:id="@+id/headerDivider"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:layout_marginTop="18dp"
        android:background="#F1F1F1"
        app:layout_constraintTop_toBottomOf="@id/headerContainer"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- ================================= -->
    <!-- WISHLIST LIST -->
    <!-- ================================= -->

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="18dp"
        android:clipToPadding="false"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingBottom="100dp"
        tools:listitem="@layout/item_wishlist_grid"
        app:layout_constraintTop_toBottomOf="@id/headerDivider"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- ================================= -->
    <!-- EMPTY STATE -->
    <!-- ================================= -->

    <LinearLayout
        android:id="@+id/emptyStateLayout"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/headerDivider"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <FrameLayout
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:background="@drawable/bg_empty_icon_circle">

            <ImageView
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_heart"
                app:tint="#222222"/>

        </FrameLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:text="No wishlists yet"
            android:textColor="#111111"
            android:textSize="20sp"
            android:fontFamily="@font/poppins_medium"/>

        <TextView
            android:layout_width="260dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:gravity="center"
            android:text="Start saving your favorite stays and experiences."
            android:textAlignment="center"
            android:textColor="#8B8B8B"
            android:textSize="15sp"
            android:fontFamily="@font/poppins_regular"/>

    </LinearLayout>

    <!-- ================================= -->
    <!-- GUEST STATE -->
    <!-- ================================= -->

    <LinearLayout
        android:id="@+id/layoutGuestPrompt"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingTop="36dp"
        android:background="#FFFFFF"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/headerDivider"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Guest Title -->
        <TextView
            android:id="@+id/tvGuestTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Log in to save listings"
            android:textColor="#111111"
            android:textSize="24sp"
            android:lineSpacingExtra="2dp"
            android:fontFamily="@font/poppins_medium"/>

        <!-- Guest Subtitle -->
        <TextView
            android:id="@+id/tvGuestSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="You can create, view, or edit Wishlists once you’ve logged in."
            android:textColor="#6A6A6A"
            android:textSize="16sp"
            android:lineSpacingExtra="2dp"
            android:fontFamily="@font/poppins_regular"/>

        <!-- Login Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnLogin"
            android:layout_width="114dp"
            android:layout_height="52dp"
            android:layout_marginTop="28dp"
            android:text="Log in"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:fontFamily="@font/poppins_medium"
            android:backgroundTint="#FF385C"
            app:cornerRadius="12dp"/>

    </LinearLayout>

    <!-- ================================= -->
    <!-- LOADING -->
    <!-- ================================= -->

    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- ================================= -->
    <!-- CREATE COLLECTION FAB -->
    <!-- ================================= -->

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabCreateCollection"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:contentDescription="Create collection"
        android:src="@android:drawable/ic_input_add"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>