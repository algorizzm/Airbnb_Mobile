<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingVertical="14dp">

    <!-- Guest Name -->
    <TextView
        android:id="@+id/tvGuestName"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Guest Name"
        android:textSize="16sp"
        android:fontFamily="@font/poppins_bold"
        android:textColor="@color/text_primary"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/tvStatus" />

    <!-- Status -->
    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Confirmed"
        android:textSize="12sp"
        android:fontFamily="@font/poppins_bold"
        android:textColor="#34A853"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Reservation Code -->
    <TextView
        android:id="@+id/tvReservationCode"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="ABC123"
        android:textSize="12sp"
        android:fontFamily="@font/poppins_medium"
        android:textColor="@color/text_secondary"
        android:layout_marginTop="2dp"
        app:layout_constraintTop_toBottomOf="@id/tvGuestName"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Dates -->
    <TextView
        android:id="@+id/tvDates"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Jan 15, 2024 - Jan 20, 2024"
        android:textSize="14sp"
        android:fontFamily="@font/poppins_bold"
        android:textColor="@color/text_primary"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/tvReservationCode"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Guests -->
    <TextView
        android:id="@+id/tvGuests"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="2 guests"
        android:textSize="14sp"
        android:fontFamily="@font/poppins_medium"
        android:textColor="@color/text_secondary"
        android:layout_marginTop="2dp"
        app:layout_constraintTop_toBottomOf="@id/tvDates"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Price -->
    <TextView
        android:id="@+id/tvPrice"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="₱5,000"
        android:textSize="16sp"
        android:fontFamily="@font/poppins_bold"
        android:textColor="@color/text_primary"
        android:layout_marginTop="4dp"
        app:layout_constraintTop_toBottomOf="@id/tvGuests"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

    <!-- Sleek Item Separator -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/divider"
        android:layout_marginTop="14dp"
        app:layout_constraintTop_toBottomOf="@id/tvPrice"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
