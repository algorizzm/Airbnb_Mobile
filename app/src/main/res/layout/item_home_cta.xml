<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingStart="16dp"
    android:paddingEnd="16dp"
    android:paddingTop="8dp"
    android:paddingBottom="4dp">

    <!-- Hero banner card -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="180dp"
        app:cardCornerRadius="16dp"
        app:cardBackgroundColor="#1A1A1A"
        app:cardElevation="0dp">

        <!-- Background image -->
        <ImageView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:src="@drawable/sample_hike"
            android:scaleType="centerCrop"
            android:contentDescription="Featured hike" />

        <!-- Dark gradient overlay -->
        <View
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/bg_gradient_dark" />

        <!-- Content on top of image -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="bottom"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ready to hit the trail?"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:fontFamily="@font/poppins_bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="Discover hikes near you"
                android:textColor="#CCFFFFFF"
                android:textSize="13sp"
                android:fontFamily="@font/poppins_regular" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnHike"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:layout_marginTop="12dp"
                android:text="Explore Hikes"
                android:textAllCaps="false"
                android:textColor="#000000"
                android:textSize="13sp"
                android:fontFamily="@font/poppins_bold"
                app:backgroundTint="#02D083"
                app:cornerRadius="20dp" />

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

</LinearLayout>
