<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingStart="16dp"
    android:paddingEnd="16dp"
    android:paddingTop="8dp"
    android:paddingBottom="4dp">

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="200dp"
        app:cardCornerRadius="16dp"
        app:cardBackgroundColor="#1A1A1A"
        app:cardElevation="0dp">

        <!-- Background image -->
        <ImageView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:src="@drawable/sample_hike"
            android:scaleType="centerCrop"
            android:contentDescription="Featured hike" />

        <!-- Dark gradient overlay -->
        <View
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/bg_gradient_dark" />

        <!-- Weather chip — top right -->
        <LinearLayout
            android:id="@+id/layoutWeather"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="top|end"
            android:layout_margin="14dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_dark_card"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/tvWeatherEmoji"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/tvWeatherTemp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:fontFamily="@font/poppins_bold" />

            <TextView
                android:id="@+id/tvWeatherCondition"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:textColor="#CCFFFFFF"
                android:textSize="12sp"
                android:fontFamily="@font/poppins_regular" />

        </LinearLayout>

        <!-- Weather loading skeleton -->
        <ProgressBar
            android:id="@+id/progressWeather"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_gravity="top|end"
            android:layout_margin="18dp"
            android:indeterminateTint="#02D083"
            android:visibility="gone" />

        <!-- Bottom content -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="bottom"
            android:padding="20dp">

            <!-- Hiking advisory badge -->
            <TextView
                android:id="@+id/tvHikingAdvisory"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:background="@drawable/bg_outline_green_pill"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingTop="3dp"
                android:paddingBottom="3dp"
                android:text="Great day to hike!"
                android:textColor="#02D083"
                android:textSize="11sp"
                android:fontFamily="@font/poppins_medium"
                android:visibility="gone" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ready to hit the trail?"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:fontFamily="@font/poppins_bold" />

            <TextView
                android:id="@+id/tvCtaSubtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="Discover hikes near you"
                android:textColor="#CCFFFFFF"
                android:textSize="13sp"
                android:fontFamily="@font/poppins_regular" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnHike"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:layout_marginTop="12dp"
                android:text="Explore Hikes"
                android:textAllCaps="false"
                android:textColor="#000000"
                android:textSize="13sp"
                android:fontFamily="@font/poppins_bold"
                app:backgroundTint="#02D083"
                app:cornerRadius="20dp" />

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

</LinearLayout>