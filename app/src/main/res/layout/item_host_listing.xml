<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="8dp"
    app:cardBackgroundColor="@color/colorSurface"
    app:cardCornerRadius="20dp"
    app:cardElevation="2dp"
    app:strokeColor="@color/divider"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="124dp"
        android:orientation="horizontal"
        android:padding="12dp">

        <!-- Listing Image -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardListingImage"
            android:layout_width="140dp"
            android:layout_height="match_parent"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp">

            <ImageView
                android:id="@+id/imgListing"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:contentDescription="Listing image"
                tools:src="@drawable/img_hike_placeholder" />

        </com.google.android.material.card.MaterialCardView>

        <!-- Right Side -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginStart="14dp"
            android:gravity="center_vertical"
            android:orientation="vertical">

            <!-- Title -->
            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:maxLines="2"
                android:ellipsize="end"
                android:textColor="@color/text_primary"
                android:textSize="15sp"
                android:fontFamily="@font/poppins_bold"
                tools:text="Beach House" />

            <!-- Property Type -->
            <TextView
                android:id="@+id/tvPropertyType"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:fontFamily="@font/poppins_medium"
                tools:text="Entire home" />

            <!-- Spacer -->
            <View
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <!-- Centered Buttons -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="horizontal">

                <!-- Edit -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnEdit"
                    style="@style/Widget.Material3.Button.IconButton"
                    android:layout_width="38dp"
                    android:layout_height="38dp"
                    android:contentDescription="Edit listing"
                    app:icon="@android:drawable/ic_menu_edit"
                    app:iconTint="@color/text_primary"
                    app:iconSize="18dp" />

                <!-- Bookings -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnViewReservations"
                    style="@style/Widget.Material3.Button.IconButton"
                    android:layout_width="38dp"
                    android:layout_height="38dp"
                    android:layout_marginStart="6dp"
                    android:contentDescription="View bookings"
                    app:icon="@drawable/ic_calendar"
                    app:iconTint="@color/text_primary"
                    app:iconSize="18dp" />

                <!-- Delete -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnDelete"
                    style="@style/Widget.Material3.Button.IconButton"
                    android:layout_width="38dp"
                    android:layout_height="38dp"
                    android:layout_marginStart="6dp"
                    android:contentDescription="Delete listing"
                    app:icon="@android:drawable/ic_menu_delete"
                    app:iconTint="@color/error_red"
                    app:iconSize="18dp" />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>