<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingVertical="14dp">

    <!-- Listing Image (Sleek Rounded Square Card) -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardListingImage"
        android:layout_width="64dp"
        android:layout_height="64dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="0dp"
        app:strokeColor="@color/divider"
        app:strokeWidth="1dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <ImageView
            android:id="@+id/ivListingImage"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:contentDescription="Listing image"
            tools:src="@drawable/ic_airbnb" />

    </com.google.android.material.card.MaterialCardView>

    <!-- Guest Name -->
    <TextView
        android:id="@+id/tvGuestName"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="14dp"
        android:textSize="16sp"
        android:fontFamily="@font/poppins_bold"
        android:textColor="@color/text_primary"
        android:maxLines="1"
        android:ellipsize="end"
        app:layout_constraintTop_toTopOf="@id/cardListingImage"
        app:layout_constraintStart_toEndOf="@id/cardListingImage"
        app:layout_constraintEnd_toEndOf="parent"
        tools:text="Michael Johnson" />

    <!-- Listing Title -->
    <TextView
        android:id="@+id/tvListingTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="14dp"
        android:layout_marginTop="2dp"
        android:textSize="14sp"
        android:fontFamily="@font/poppins_medium"
        android:textColor="@color/text_secondary"
        android:maxLines="1"
        android:ellipsize="end"
        app:layout_constraintTop_toBottomOf="@id/tvGuestName"
        app:layout_constraintStart_toEndOf="@id/cardListingImage"
        app:layout_constraintEnd_toEndOf="parent"
        tools:text="Beachfront Villa" />

    <!-- Nights Remaining -->
    <TextView
        android:id="@+id/tvNightsRemaining"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="14dp"
        android:layout_marginTop="4dp"
        android:textSize="13sp"
        android:fontFamily="@font/poppins_medium"
        android:textColor="#484848"
        app:layout_constraintTop_toBottomOf="@id/tvListingTitle"
        app:layout_constraintStart_toEndOf="@id/cardListingImage"
        app:layout_constraintEnd_toEndOf="parent"
        tools:text="3 nights remaining" />

    <!-- Reservation Info -->
    <TextView
        android:id="@+id/tvReservationInfo"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:textSize="13sp"
        android:fontFamily="@font/poppins_medium"
        android:textColor="@color/text_secondary"
        app:layout_constraintTop_toBottomOf="@id/cardListingImage"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/btnViewReservation"
        app:layout_constraintBottom_toBottomOf="parent"
        tools:text="2 guests • Code: ABC123" />

    <!-- View Reservation Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnViewReservation"
        android:layout_width="wrap_content"
        android:layout_height="36dp"
        android:text="View"
        android:textSize="13sp"
        android:fontFamily="@font/poppins_bold"
        android:textAllCaps="false"
        android:textColor="@color/airbnb_red"
        style="@style/Widget.Material3.Button.TextButton"
        app:layout_constraintTop_toBottomOf="@id/cardListingImage"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

    <!-- Sleek Item Separator -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/divider"
        android:layout_marginTop="14dp"
        app:layout_constraintTop_toBottomOf="@id/btnViewReservation"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
