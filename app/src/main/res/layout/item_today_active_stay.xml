<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="20dp"
    android:layout_marginVertical="6dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp"
    app:strokeWidth="0dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <!-- Listing Image -->
        <ImageView
            android:id="@+id/ivListingImage"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:scaleType="centerCrop"
            android:contentDescription="Listing image"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            tools:src="@drawable/ic_airbnb" />

        <!-- Guest Name -->
        <TextView
            android:id="@+id/tvGuestName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#1A1A1A"
            android:maxLines="1"
            android:ellipsize="end"
            app:layout_constraintTop_toTopOf="@id/ivListingImage"
            app:layout_constraintStart_toEndOf="@id/ivListingImage"
            app:layout_constraintEnd_toEndOf="parent"
            tools:text="Michael Johnson" />

        <!-- Listing Title -->
        <TextView
            android:id="@+id/tvListingTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginTop="2dp"
            android:textSize="14sp"
            android:textColor="#717171"
            android:maxLines="1"
            android:ellipsize="end"
            app:layout_constraintTop_toBottomOf="@id/tvGuestName"
            app:layout_constraintStart_toEndOf="@id/ivListingImage"
            app:layout_constraintEnd_toEndOf="parent"
            tools:text="Beachfront Villa" />

        <!-- Nights Remaining -->
        <TextView
            android:id="@+id/tvNightsRemaining"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginTop="4dp"
            android:textSize="13sp"
            android:textColor="#484848"
            app:layout_constraintTop_toBottomOf="@id/tvListingTitle"
            app:layout_constraintStart_toEndOf="@id/ivListingImage"
            app:layout_constraintEnd_toEndOf="parent"
            tools:text="3 nights remaining" />

        <!-- Reservation Info -->
        <TextView
            android:id="@+id/tvReservationInfo"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:textSize="13sp"
            android:textColor="#717171"
            app:layout_constraintTop_toBottomOf="@id/ivListingImage"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/btnViewReservation"
            tools:text="2 guests • Code: ABC123" />

        <!-- View Reservation Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnViewReservation"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="View"
            android:textSize="13sp"
            android:textAllCaps="false"
            style="@style/Widget.Material3.Button.TextButton"
            app:layout_constraintTop_toBottomOf="@id/ivListingImage"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>
