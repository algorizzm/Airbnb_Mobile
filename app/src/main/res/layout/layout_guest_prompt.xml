<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/layoutGuestPrompt"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="32dp"
    android:visibility="gone">

    <!-- Icon -->
    <ImageView
        android:id="@+id/imgGuestIcon"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:src="@drawable/ic_profile"
        android:alpha="0.5"
        app:tint="@color/gray" />

    <!-- Title -->
    <TextView
        android:id="@+id/tvGuestTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Sign in to continue"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="@color/text_primary"
        android:gravity="center" />

    <!-- Message -->
    <TextView
        android:id="@+id/tvGuestMessage"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Create an account or log in to access this feature"
        android:textSize="14sp"
        android:textColor="@color/text_secondary"
        android:gravity="center"
        android:maxWidth="280dp" />

    <!-- Sign In Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnGuestSignIn"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="Sign In"
        android:textAllCaps="false"
        android:paddingHorizontal="32dp"
        app:cornerRadius="8dp"
        style="@style/Widget.Material3.Button" />

    <!-- Sign Up Link -->
    <TextView
        android:id="@+id/tvGuestSignUp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="Don't have an account? Sign up"
        android:textSize="14sp"
        android:textColor="@color/airbnb_red"
        android:clickable="true"
        android:focusable="true"
        android:padding="8dp" />

</LinearLayout>
