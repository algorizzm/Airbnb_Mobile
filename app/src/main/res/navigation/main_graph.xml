<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main_graph"
    app:startDestination="@id/exploreFragment">

    <!-- Home -->
    <fragment
        android:id="@+id/homeFragment"
        android:name="com.airbnb.ui.home.HomeFragment"
        android:label="Home" />

    <!-- Post Detail -->
    <fragment
        android:id="@+id/postDetailFragment"
        android:name="com.airbnb.ui.home.PostDetailFragment"
        android:label="Post" />

    <!-- Explore -->
    <fragment
        android:id="@+id/exploreFragment"
        android:name="com.airbnb.ui.traveler.explore.ExploreFragment"
        android:label="Explore">

        <action
            android:id="@+id/action_exploreFragment_to_listingDetailFragment"
            app:destination="@id/listingDetailFragment" />

    </fragment>

    <!-- Wishlist -->
    <fragment
        android:id="@+id/wishlistFragment"
        android:name="com.airbnb.ui.traveler.wishlist.WishlistFragment"
        android:label="Wishlists">

        <action
            android:id="@+id/action_wishlistFragment_to_listingDetailFragment"
            app:destination="@id/listingDetailFragment" />

    </fragment>

    <!-- Trips -->
    <fragment
        android:id="@+id/tripsFragment"
        android:name="com.airbnb.ui.traveler.trips.TripsFragment"
        android:label="Trips">

        <action
            android:id="@+id/action_tripsFragment_to_listingDetailFragment"
            app:destination="@id/listingDetailFragment" />

    </fragment>

    <!-- Profile -->
    <fragment
        android:id="@+id/profileFragment"
        android:name="com.airbnb.ui.shared.profile.ProfileFragment"
        android:label="Profile">

        <action
            android:id="@+id/action_profileFragment_to_loginFragment"
            app:destination="@id/auth_graph" />

        <action
            android:id="@+id/action_profileFragment_to_listingDetailFragment"
            app:destination="@id/listingDetailFragment" />

        <action
            android:id="@+id/action_profileFragment_to_hostListingsFragment"
            app:destination="@id/hostListingsFragment" />

    </fragment>

    <!-- Host Listings -->
    <fragment
        android:id="@+id/hostListingsFragment"
        android:name="com.airbnb.ui.host.listings.HostListingsFragment"
        android:label="My Listings">

        <action
            android:id="@+id/action_hostListingsFragment_to_createListingFragment"
            app:destination="@id/createListingFragment" />

        <action
            android:id="@+id/action_hostListingsFragment_to_hostReservationsFragment"
            app:destination="@id/hostReservationsFragment" />

    </fragment>

    <!-- Create/Edit Listing -->
    <fragment
        android:id="@+id/createListingFragment"
        android:name="com.airbnb.ui.host.listings.create.CreateListingFragment"
        android:label="Create Listing" />

    <!-- Host Reservations -->
    <fragment
        android:id="@+id/hostReservationsFragment"
        android:name="com.airbnb.ui.host.reservation.HostReservationsFragment"
        android:label="Reservations" />

    <!-- Host Today (cross-listing reservation inbox — host mode root tab) -->
    <fragment
        android:id="@+id/hostTodayFragment"
        android:name="com.airbnb.ui.host.today.HostTodayFragment"
        android:label="Today" />

    <!-- Host Calendar (placeholder — host mode root tab) -->
    <fragment
        android:id="@+id/hostCalendarFragment"
        android:name="com.airbnb.ui.host.calendar.HostCalendarFragment"
        android:label="Calendar" />

    <!-- Listing Details -->
    <fragment
        android:id="@+id/listingDetailFragment"
        android:name="com.airbnb.ui.listings.ListingDetailFragment"
        android:label="Listing details">

        <action
            android:id="@+id/action_listingDetailFragment_to_createReservationFragment"
            app:destination="@id/createReservationFragment" />

    </fragment>

    <!-- Create Reservation -->
    <fragment
        android:id="@+id/createReservationFragment"
        android:name="com.airbnb.ui.reservations.CreateReservationFragment"
        android:label="Reserve" />

    <!-- Messages -->
    <fragment
        android:id="@+id/messagesFragment"
        android:name="com.airbnb.ui.shared.messages.MessagesFragment"
        android:label="Messages" />

    <!-- Settings -->
    <fragment
        android:id="@+id/settingsFragment"
        android:name="com.airbnb.ui.shared.settings.SettingsFragment"
        android:label="Settings">

        <action
            android:id="@+id/action_settingsFragment_to_accountInformationFragment"
            app:destination="@id/accountInformationFragment" />

        <action
            android:id="@+id/action_settingsFragment_to_privacySecurityFragment"
            app:destination="@id/privacySecurityFragment" />

        <action
            android:id="@+id/action_settingsFragment_to_notificationsFragment"
            app:destination="@id/notificationSettingsFragment" />

    </fragment>

    <!-- Account Information -->
    <fragment
        android:id="@+id/accountInformationFragment"
        android:name="com.airbnb.ui.shared.settings.AccountInformationFragment"
        android:label="Account Information">

        <action
            android:id="@+id/action_accountInformationFragment_to_editProfileFragment"
            app:destination="@id/editProfileFragment" />

    </fragment>

    <!-- Edit Profile -->
    <fragment
        android:id="@+id/editProfileFragment"
        android:name="com.airbnb.ui.shared.settings.EditProfileFragment"
        android:label="Edit Profile" />

    <!-- Privacy & Security -->
    <fragment
        android:id="@+id/privacySecurityFragment"
        android:name="com.airbnb.ui.shared.settings.PrivacySecurityFragment"
        android:label="Privacy and Security" />

    <!-- Notification Settings (from Settings screen) -->
    <fragment
        android:id="@+id/notificationSettingsFragment"
        android:name="com.airbnb.ui.shared.settings.NotificationsFragment"
        android:label="Notification Settings" />

    <!-- Notification Inbox (from main screen bell icon) -->
    <fragment
        android:id="@+id/notificationsFragment"
        android:name="com.airbnb.ui.shared.notifications.NotificationInboxFragment"
        android:label="Notifications" />

    <!-- Change Password -->
    <fragment
        android:id="@+id/changePasswordFragment"
        android:name="com.airbnb.ui.shared.settings.ChangePasswordFragment"
        android:label="Change Password" />

</navigation>

