<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main_graph"
    app:startDestination="@id/exploreFragment">

    <!-- Home -->
    <fragment
        android:id="@+id/homeFragment"
        android:name="com.airbnb.ui.home.HomeFragment"
        android:label="Home">

        <action
            android:id="@+id/action_homeFragment_to_hikesFragment"
            app:destination="@id/hikeFragment" />

    </fragment>

    <!-- Post Detail -->
    <fragment
        android:id="@+id/postDetailFragment"
        android:name="com.airbnb.ui.home.PostDetailFragment"
        android:label="Post" />

    <!-- Explore -->
    <fragment
        android:id="@+id/exploreFragment"
        android:name="com.airbnb.ui.explore.ExploreFragment"
        android:label="Explore">

        <action
            android:id="@+id/action_exploreFragment_to_hikeDetailFragment"
            app:destination="@id/hikeDetailFragment" />

        <action
            android:id="@+id/action_exploreFragment_to_listingDetailFragment"
            app:destination="@id/listingDetailFragment" />

    </fragment>

    <!-- Wishlist -->
    <fragment
        android:id="@+id/wishlistFragment"
        android:name="com.airbnb.ui.wishlist.WishlistFragment"
        android:label="Wishlists">

        <action
            android:id="@+id/action_wishlistFragment_to_listingDetailFragment"
            app:destination="@id/listingDetailFragment" />

    </fragment>

    <!-- Trips -->
    <fragment
        android:id="@+id/tripsFragment"
        android:name="com.airbnb.ui.trips.TripsFragment"
        android:label="Trips">

        <action
            android:id="@+id/action_tripsFragment_to_listingDetailFragment"
            app:destination="@id/listingDetailFragment" />

    </fragment>

    <!-- Profile -->
    <fragment
        android:id="@+id/profileFragment"
        android:name="com.airbnb.ui.profile.ProfileFragment"
        android:label="Profile">

        <action
            android:id="@+id/action_profileFragment_to_loginFragment"
            app:destination="@id/auth_graph" />

        <action
            android:id="@+id/action_profileFragment_to_hikeDetailFragment"
            app:destination="@id/hikeDetailFragment" />

    </fragment>

    <!-- Hike -->
    <fragment
        android:id="@+id/hikeFragment"
        android:name="com.airbnb.ui.hikes.HikesFragment"
        android:label="Hike">

        <action
            android:id="@+id/action_hikeFragment_to_createEditHikeFragment"
            app:destination="@id/createEditHikeFragment" />

        <action
            android:id="@+id/action_hikeFragment_to_hikeDetailFragment"
            app:destination="@id/hikeDetailFragment" />

        <action
            android:id="@+id/action_hikeFragment_to_eventsFragment"
            app:destination="@id/eventsFragment" />

    </fragment>

    <!-- Hike Details -->
    <fragment
        android:id="@+id/hikeDetailFragment"
        android:name="com.airbnb.ui.explore.HikeDetailFragment"
        android:label="Hike details" />

    <!-- Listing Details -->
    <fragment
        android:id="@+id/listingDetailFragment"
        android:name="com.airbnb.ui.listings.ListingDetailFragment"
        android:label="Listing details">

        <action
            android:id="@+id/action_listingDetailFragment_to_createReservationFragment"
            app:destination="@id/createReservationFragment" />

    </fragment>

    <!-- Create Reservation -->
    <fragment
        android:id="@+id/createReservationFragment"
        android:name="com.airbnb.ui.reservations.CreateReservationFragment"
        android:label="Reserve" />

    <!-- Create/Edit Hike (multi-step host) -->
    <fragment
        android:id="@+id/createEditHikeFragment"
        android:name="com.airbnb.ui.hikes.create.CreateHikeHostFragment"
        android:label="Create or edit hike" />

    <!-- Events -->
    <fragment
        android:id="@+id/eventsFragment"
        android:name="com.airbnb.ui.hikes.events.EventsFragment"
        android:label="Your Hiking Events">

        <action
            android:id="@+id/action_eventsFragment_to_createEditHikeFragment"
            app:destination="@id/createEditHikeFragment" />

        <action
            android:id="@+id/action_eventsFragment_to_hikeDetailFragment"
            app:destination="@id/hikeDetailFragment" />

    </fragment>

    <!-- History -->
    <fragment
        android:id="@+id/hikeHistoryFragment"
        android:name="com.airbnb.ui.hikes.history.HikeHistoryFragment"
        android:label="Your Hiking History">

        <action
            android:id="@+id/action_hikeHistoryFragment_to_hikeDetailFragment"
            app:destination="@id/hikeDetailFragment" />

    </fragment>

    <!-- Applicants -->
    <fragment
        android:id="@+id/applicantsFragment"
        android:name="com.airbnb.ui.hikes.ApplicantsFragment"
        android:label="Applicants" />

    <!-- My Bookings -->
    <fragment
        android:id="@+id/myBookingsFragment"
        android:name="com.airbnb.ui.hikes.history.HikeHistoryFragment"
        android:label="My bookings">

        <action
            android:id="@+id/action_myBookingsFragment_to_hikeDetailFragment"
            app:destination="@id/hikeDetailFragment" />

    </fragment>

    <!-- Messages -->
    <fragment
        android:id="@+id/messagesFragment"
        android:name="com.airbnb.ui.messages.MessagesFragment"
        android:label="Messages" />

    <!-- Settings -->
    <fragment
        android:id="@+id/settingsFragment"
        android:name="com.airbnb.ui.settings.SettingsFragment"
        android:label="Settings">

        <action
            android:id="@+id/action_settingsFragment_to_accountInformationFragment"
            app:destination="@id/accountInformationFragment" />

        <action
            android:id="@+id/action_settingsFragment_to_privacySecurityFragment"
            app:destination="@id/privacySecurityFragment" />

        <action
            android:id="@+id/action_settingsFragment_to_notificationsFragment"
            app:destination="@id/notificationSettingsFragment" />

    </fragment>

    <!-- Account Information -->
    <fragment
        android:id="@+id/accountInformationFragment"
        android:name="com.airbnb.ui.settings.AccountInformationFragment"
        android:label="Account Information">

        <action
            android:id="@+id/action_accountInformationFragment_to_editProfileFragment"
            app:destination="@id/editProfileFragment" />

    </fragment>

    <!-- Edit Profile -->
    <fragment
        android:id="@+id/editProfileFragment"
        android:name="com.airbnb.ui.settings.EditProfileFragment"
        android:label="Edit Profile" />

    <!-- Privacy & Security -->
    <fragment
        android:id="@+id/privacySecurityFragment"
        android:name="com.airbnb.ui.settings.PrivacySecurityFragment"
        android:label="Privacy and Security" />

    <!-- Notification Settings (from Settings screen) -->
    <fragment
        android:id="@+id/notificationSettingsFragment"
        android:name="com.airbnb.ui.settings.NotificationsFragment"
        android:label="Notification Settings" />

    <!-- Notification Inbox (from main screen bell icon) -->
    <fragment
        android:id="@+id/notificationsFragment"
        android:name="com.airbnb.ui.notifications.NotificationInboxFragment"
        android:label="Notifications" />

    <!-- Change Password -->
    <fragment
        android:id="@+id/changePasswordFragment"
        android:name="com.airbnb.ui.settings.ChangePasswordFragment"
        android:label="Change Password" />

</navigation>

