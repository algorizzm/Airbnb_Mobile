<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/public_nested_graph"
    app:startDestination="@id/splashFragment">

    <fragment
        android:id="@+id/splashFragment"
        android:name="com.airbnb.ui.main.SplashFragment"
        android:label="Launcher" />

    <!-- Sprint 10: Manual Email/Password Authentication -->
    <fragment
        android:id="@+id/loginFragment"
        android:name="com.airbnb.ui.auth.LoginFragment"
        android:label="Log In">
        <action
            android:id="@+id/action_loginFragment_to_signupFragment"
            app:destination="@id/signupFragment"
            app:enterAnim="@anim/nav_enter"
            app:exitAnim="@anim/nav_exit"
            app:popEnterAnim="@anim/nav_pop_enter"
            app:popExitAnim="@anim/nav_pop_exit" />
        <argument
            android:name="destId"
            android:defaultValue="0"
            app:argType="integer" />
        <argument
            android:name="destArgs"
            android:defaultValue="@null"
            app:argType="android.os.Bundle"
            app:nullable="true" />
    </fragment>

    <fragment
        android:id="@+id/signupFragment"
        android:name="com.airbnb.ui.auth.SignupFragment"
        android:label="Sign Up">
        <action
            android:id="@+id/action_signupFragment_to_loginFragment"
            app:destination="@id/loginFragment"
            app:enterAnim="@anim/nav_enter"
            app:exitAnim="@anim/nav_exit"
            app:popEnterAnim="@anim/nav_pop_enter"
            app:popExitAnim="@anim/nav_pop_exit" />
        <argument
            android:name="destId"
            android:defaultValue="0"
            app:argType="integer" />
        <argument
            android:name="destArgs"
            android:defaultValue="@null"
            app:argType="android.os.Bundle"
            app:nullable="true" />
    </fragment>

</navigation>