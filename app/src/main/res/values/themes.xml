<resources xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Base application theme. -->
    <style name="Base.Theme.Airbnb" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Customize your light theme here. -->
        <!-- <item name="colorPrimary">@color/my_light_primary</item> -->
    </style>

    <style name="Theme.Airbnb" parent="Base.Theme.Airbnb">
        <!-- Brand Colors -->
        <item name="colorPrimary">#4CAF50</item>
        <item name="colorSecondary">#81C784</item>

        <!-- Material Picker Themes -->
        <item name="materialCalendarTheme">@style/AirbnbCalendarTheme</item>
        <item name="materialTimePickerTheme">@style/AirbnbTimePickerTheme</item>
    </style>

        <style name="AirbnbTag">
            <item name="android:layout_width">wrap_content</item>
            <item name="android:layout_height">wrap_content</item>
            <item name="android:background">@drawable/bg_tag_pill</item>
            <item name="android:paddingStart">16dp</item>
            <item name="android:paddingEnd">16dp</item>
            <item name="android:paddingTop">4dp</item>
            <item name="android:paddingBottom">4dp</item>
            <item name="android:textColor">#0B301F</item>
            <item name="android:textSize">12sp</item>
            <item name="android:gravity">center</item>
        </style>

        <style name="AirbnbDivider">
            <item name="android:layout_width">match_parent</item>
            <item name="android:layout_height">1dp</item>
            <item name="android:background">#E0E0E0</item>
            <item name="android:layout_marginTop">8dp</item>
            <item name="android:layout_marginBottom">8dp</item>
        </style>

        <style name="AirbnbSectionLabel">
            <item name="android:layout_width">wrap_content</item>
            <item name="android:layout_height">wrap_content</item>
            <item name="android:textColor">#8CA99C</item>
            <item name="android:textSize">12sp</item>
            <item name="android:textStyle">bold</item>
        </style>

        <style name="AirbnbFieldLabel">
            <item name="android:layout_width">wrap_content</item>
            <item name="android:layout_height">wrap_content</item>
            <item name="android:textColor">#0B301F</item>
            <item name="android:textSize">14sp</item>
            <item name="android:textStyle">bold</item>
        </style>

        <style name="AirbnbEditText" parent="Widget.AppCompat.EditText">
            <item name="android:layout_width">match_parent</item>
            <item name="android:layout_height">wrap_content</item>
            <item name="android:background">@drawable/bg_edit_field</item>
            <item name="android:padding">12dp</item>
            <item name="android:textColor">#000000</item>
            <item name="android:textSize">14sp</item>
        </style>

        <style name="AirbnbLevelButton">
            <item name="android:layout_width">0dp</item>
            <item name="android:layout_height">wrap_content</item>
            <item name="android:layout_weight">1</item>
            <item name="android:background">@drawable/bg_edit_field</item>
            <item name="android:gravity">center</item>
            <item name="android:padding">10dp</item>
            <item name="android:textColor">#0B301F</item>
            <item name="android:textSize">12sp</item>
        </style>

        <style name="AirbnbLevelButtonActive">
            <item name="android:layout_width">0dp</item>
            <item name="android:layout_height">wrap_content</item>
            <item name="android:layout_weight">1</item>
            <item name="android:background">@drawable/bg_active_level</item>
            <item name="android:gravity">center</item>
            <item name="android:padding">10dp</item>
            <item name="android:textColor">#FFFFFF</item>
            <item name="android:textSize">12sp</item>
            <item name="android:textStyle">bold</item>
        </style>

        <style name="AirbnbCircleImageView">
            <item name="cornerFamily">rounded</item>
            <item name="cornerSize">50%</item>
        </style>

        <style name="AirbnbCalendarTheme"
            parent="ThemeOverlay.Material3.MaterialCalendar">
            <item name="colorPrimary">#4CAF50</item>
            <item name="colorOnPrimary">#FFFFFF</item>
        </style>

        <style name="AirbnbTimePickerTheme"
            parent="ThemeOverlay.Material3.MaterialTimePicker">
            <item name="colorPrimary">#4CAF50</item>
            <item name="colorOnPrimary">#FFFFFF</item>
        </style>

</resources>