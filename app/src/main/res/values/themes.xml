<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- ========================================================= -->
    <!-- BASE THEME -->
    <!-- ========================================================= -->

    <style
        name="Base.Theme.Airbnb"
        parent="Theme.Material3.DayNight.NoActionBar">

        <!-- ========================= -->
        <!-- PRIMARY COLORS -->
        <!-- ========================= -->

        <item name="colorPrimary">@color/airbnb_red</item>
        <item name="colorOnPrimary">@color/white</item>

        <item name="colorPrimaryContainer">@color/airbnb_red</item>
        <item name="colorOnPrimaryContainer">@color/white</item>

        <!-- ========================= -->
        <!-- SECONDARY COLORS -->
        <!-- ========================= -->

        <item name="colorSecondary">@color/airbnb_red_dark</item>
        <item name="colorOnSecondary">@color/white</item>

        <item name="colorSecondaryContainer">@color/airbnb_red_dark</item>
        <item name="colorOnSecondaryContainer">@color/white</item>

        <!-- ========================= -->
        <!-- TERTIARY COLORS -->
        <!-- ========================= -->

        <item name="colorTertiary">@color/airbnb_red_light</item>

        <!-- ========================= -->
        <!-- BACKGROUND / SURFACES -->
        <!-- ========================= -->

        <item name="android:colorBackground">@color/colorBackground</item>

        <item name="colorSurface">@color/colorSurface</item>
        <item name="colorSurfaceVariant">@color/colorSurface2</item>

        <!-- ========================= -->
        <!-- MATERIAL CONTROLS -->
        <!-- ========================= -->

        <!-- Controls: switch, checkbox, slider, radio -->
        <item name="colorControlActivated">@color/airbnb_red</item>

        <!-- Ripple color -->
        <item name="colorControlHighlight">@color/airbnb_red_light</item>

        <!-- ========================= -->
        <!-- SYSTEM BARS -->
        <!-- ========================= -->

        <!-- Status bar -->
        <item name="android:statusBarColor">@color/white</item>
        <item name="android:windowLightStatusBar">true</item>

        <!-- Navigation bar -->
        <item name="android:navigationBarColor">@color/white</item>
        <item name="android:windowLightNavigationBar">true</item>

        <!-- ========================= -->
        <!-- MATERIAL COMPONENTS -->
        <!-- ========================= -->

        <item name="materialButtonStyle">
            @style/AirbnbMaterialButton
        </item>

    </style>

    <!-- ========================================================= -->
    <!-- MAIN APP THEME -->
    <!-- ========================================================= -->

    <style
        name="Theme.Airbnb"
        parent="Base.Theme.Airbnb">

        <!-- Material Date Picker -->
        <item name="materialCalendarTheme">
            @style/AirbnbCalendarTheme
        </item>

        <!-- Material Time Picker -->
        <item name="materialTimePickerTheme">
            @style/AirbnbTimePickerTheme
        </item>

    </style>

    <!-- ========================================================= -->
    <!-- BUTTON STYLES -->
    <!-- ========================================================= -->

    <style
        name="AirbnbMaterialButton"
        parent="Widget.Material3.Button">

        <item name="backgroundTint">@color/airbnb_red</item>
        <item name="android:textColor">@color/white</item>

    </style>

    <!-- ========================================================= -->
    <!-- TAG STYLE -->
    <!-- ========================================================= -->

    <style name="AirbnbTag">

        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>

        <item name="android:background">@drawable/bg_tag_pill</item>

        <item name="android:paddingStart">16dp</item>
        <item name="android:paddingEnd">16dp</item>

        <item name="android:paddingTop">4dp</item>
        <item name="android:paddingBottom">4dp</item>

        <item name="android:textColor">@color/airbnb_black</item>
        <item name="android:textSize">12sp</item>

        <item name="android:gravity">center</item>

    </style>

    <!-- ========================================================= -->
    <!-- DIVIDER -->
    <!-- ========================================================= -->

    <style name="AirbnbDivider">

        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">1dp</item>

        <item name="android:background">@color/divider</item>

        <item name="android:layout_marginTop">8dp</item>
        <item name="android:layout_marginBottom">8dp</item>

    </style>

    <!-- ========================================================= -->
    <!-- TEXT STYLES -->
    <!-- ========================================================= -->

    <style name="AirbnbSectionLabel">

        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>

        <item name="android:textColor">@color/airbnb_gray</item>
        <item name="android:textSize">12sp</item>
        <item name="android:textStyle">bold</item>

    </style>

    <style name="AirbnbFieldLabel">

        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>

        <item name="android:textColor">@color/airbnb_black</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">bold</item>

    </style>

    <!-- ========================================================= -->
    <!-- INPUT FIELDS -->
    <!-- ========================================================= -->

    <style
        name="AirbnbEditText"
        parent="Widget.AppCompat.EditText">

        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>

        <item name="android:background">@drawable/bg_edit_field</item>

        <item name="android:padding">12dp</item>

        <item name="android:textColor">@color/black</item>
        <item name="android:textSize">14sp</item>

    </style>

    <!-- ========================================================= -->
    <!-- LEVEL BUTTONS -->
    <!-- ========================================================= -->

    <style name="AirbnbLevelButton">

        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>

        <item name="android:layout_weight">1</item>

        <item name="android:background">@drawable/bg_edit_field</item>

        <item name="android:gravity">center</item>

        <item name="android:padding">10dp</item>

        <item name="android:textColor">@color/airbnb_black</item>
        <item name="android:textSize">12sp</item>

    </style>

    <style name="AirbnbLevelButtonActive">

        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>

        <item name="android:layout_weight">1</item>

        <item name="android:background">@drawable/bg_active_level</item>

        <item name="android:gravity">center</item>

        <item name="android:padding">10dp</item>

        <item name="android:textColor">@color/white</item>
        <item name="android:textSize">12sp</item>
        <item name="android:textStyle">bold</item>

    </style>

    <!-- ========================================================= -->
    <!-- IMAGE STYLES -->
    <!-- ========================================================= -->

    <style name="AirbnbCircleImageView">

        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>

    </style>

    <!-- ========================================================= -->
    <!-- MATERIAL DATE PICKER -->
    <!-- ========================================================= -->

    <style
        name="AirbnbCalendarTheme"
        parent="ThemeOverlay.Material3.MaterialCalendar">

        <item name="colorPrimary">@color/airbnb_red</item>
        <item name="colorOnPrimary">@color/white</item>

        <item name="colorSurface">@color/white</item>

    </style>

    <!-- ========================================================= -->
    <!-- MATERIAL TIME PICKER -->
    <!-- ========================================================= -->

    <style
        name="AirbnbTimePickerTheme"
        parent="ThemeOverlay.Material3.MaterialTimePicker">

        <item name="colorPrimary">@color/airbnb_red</item>
        <item name="colorOnPrimary">@color/white</item>

    </style>

    <!-- ========================================================= -->
    <!-- BOTTOM SHEET -->
    <!-- ========================================================= -->

    <style
        name="RoundedBottomSheetDialog"
        parent="Theme.Material3.Light.BottomSheetDialog">

        <item name="bottomSheetStyle">
            @style/CustomBottomSheetStyle
        </item>

    </style>

    <style
        name="CustomBottomSheetStyle"
        parent="Widget.Material3.BottomSheet.Modal">

        <item name="android:background">
            @android:color/transparent
        </item>

    </style>

</resources>